---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import { BRAND, SITE_URL, type Locale } from "../../config";
import { resolveLocale, localizePath } from "../../i18n/utils";
import { webPageSchema, breadcrumbSchema, itemListSchema } from "../../lib/schema";

const locale: Locale = resolveLocale(Astro.currentLocale);
const path = "/industries";
const pageUrl = new URL(localizePath(path, locale), SITE_URL).href;
const contact = localizePath("/contact", locale);

const title = `Industries — AI Video Analytics by Sector | ${BRAND.name}`;
const description = `${BRAND.name} delivers agentic AI video analytics on existing CCTV across retail, QSR, dark stores, manufacturing, logistics and more — footfall, conversion, safety, productivity and loss prevention with WhatsApp alerts.`;

const answer = `${BRAND.name} delivers agentic AI video analytics tailored to each industry, running on the CCTV cameras you already own. Retail teams track footfall and conversion, QSRs monitor drive-thru and kitchen SOPs, dark stores measure pick-pack productivity, and manufacturers enforce PPE and safety compliance — all with plain-language questions and WhatsApp alerts, no new hardware.`;

const industries = [
  { name: "Retail", href: "/industries/retail-video-analytics", live: true, blurb: "Convert footfall into revenue and stop shrinkage across every store.", points: ["Footfall & conversion", "Queue & checkout alerts", "Loss prevention"] },
  { name: "QSR & restaurants", href: "/industries", live: false, blurb: "Speed up service and protect quality at the counter and drive-thru.", points: ["Drive-thru & counter speed", "Kitchen hygiene & SOP", "Order accuracy"] },
  { name: "Dark stores & quick commerce", href: "/industries", live: false, blurb: "Lift fulfilment productivity and protect dispatch SLAs.", points: ["Pick & pack productivity", "Dispatch SLA tracking", "Shrinkage detection"] },
  { name: "Manufacturing", href: "/industries", live: false, blurb: "Enforce PPE and safety compliance and track line productivity.", points: ["PPE & SOP compliance", "Line output", "Intrusion detection"] },
  { name: "Logistics & warehousing", href: "/industries", live: false, blurb: "Monitor dock operations, safety and throughput in real time.", points: ["Dock & bay utilisation", "Safety compliance", "Throughput tracking"] },
  { name: "Education", href: "/industries", live: false, blurb: "Keep campuses safe with privacy-first behavioural monitoring.", points: ["Campus safety", "Attendance insights", "After-hours alerts"] },
];

const schema = [
  webPageSchema({ url: pageUrl, name: title, description, image: "/og/default.png" }),
  itemListSchema(
    "Industries served by ShopEye",
    industries.map((i) => ({ name: i.name, description: i.blurb })),
  ),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Industries", url: path },
  ]),
];
---
<BaseLayout title={title} description={description} path={path} schema={schema}>
  <section class="bg-grid relative overflow-hidden">
    <div class="glow-radial pointer-events-none absolute inset-0"></div>
    <div class="container-x relative py-16 md:py-24">
      <nav class="mb-6 flex items-center gap-2 text-xs text-faint" aria-label="Breadcrumb">
        <a href={localizePath("/", locale)} class="hover:text-ink">Home</a>
        <span>/</span>
        <span class="text-ink">Industries</span>
      </nav>
      <span class="eyebrow">Industries we serve</span>
      <h1 class="mt-3 max-w-3xl text-balance text-4xl font-semibold leading-[1.08] tracking-tight text-ink md:text-5xl">
        AI video analytics built for <span class="text-brand-600">your industry</span>
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted">{description}</p>
    </div>
  </section>

  <section class="container-x -mt-6 relative z-10 pb-12">
    <div class="surface-card p-6 md:p-8" data-answer>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-600">Quick answer — Which industries does {BRAND.name} serve?</h2>
      <p class="mt-2 text-base leading-relaxed text-ink">{answer}</p>
    </div>
  </section>

  <section class="container-x pb-16 md:pb-24">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {industries.map((ind) => (
        <a href={localizePath(ind.href, locale)} class="surface-card group flex flex-col p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-float)]">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold text-ink">{ind.name}</h3>
            {ind.live ? (
              <span class="rounded-full bg-signal-50 px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-wider text-signal-600">Live</span>
            ) : (
              <span class="rounded-full bg-mist px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-wider text-faint">Soon</span>
            )}
          </div>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{ind.blurb}</p>
          <ul class="mt-4 flex flex-wrap gap-2">
            {ind.points.map((pt) => (
              <li class="inline-flex items-center gap-1.5 rounded-full border border-line bg-mist px-2.5 py-1 text-xs text-muted">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand-500"><path d="M20 6 9 17l-5-5"/></svg>
                {pt}
              </li>
            ))}
          </ul>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-brand-600">
            {ind.live ? "Explore" : "Coming soon"}
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-gradient-to-br from-brand-600 via-brand-700 to-brand-800">
    <div class="container-x py-16 text-center md:py-20">
      <h2 class="text-3xl font-semibold tracking-tight text-white md:text-4xl">See {BRAND.name} on your own cameras</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/80">A 30-minute walkthrough tailored to your sector — no new hardware, no commitment.</p>
      <div class="mt-8 flex justify-center">
        <Button href={contact} size="lg">
          Book a demo
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
