---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import CapabilityIcon from "../../components/CapabilityIcon.astro";
import StepIcon from "../../components/StepIcon.astro";
import AskShopEye from "../../components/AskShopEye.astro";
import ContactDemo from "../../components/ContactDemo.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import AuthorityCitations from "../../components/AuthorityCitations.astro";
import { educationCitations } from "../../lib/industry-citations";
import { BRAND, SITE_URL, type Locale } from "../../config";
import { resolveLocale, localizePath } from "../../i18n/utils";
import {
  webPageSchema,
  faqSchema,
  breadcrumbSchema,
  howToSchema,
  itemListSchema,
} from "../../lib/schema";

const locale: Locale = resolveLocale(Astro.currentLocale);
const path = "/industries/education-video-analytics";
const pageUrl = new URL(localizePath(path, locale), SITE_URL).href;
const contact = localizePath("/contact", locale);

const title = `Education & Campus Video Analytics for Schools & Colleges | ${BRAND.name}`;
const description = `${BRAND.name} education video analytics turns existing campus CCTV into automated attendance, exam integrity monitoring, campus safety alerts, unauthorized access detection, crowding alerts, and emergency response acceleration — no facial recognition, no new hardware. Built for Indian schools, colleges, and multi-campus institutions.`;

const faqItems = [
  { q: "What is education video analytics?", a: `Education video analytics is AI software that processes existing campus CCTV feeds in real time to automate attendance, detect safety incidents, monitor exam halls, flag unauthorized access, and alert on crowding or after-hours intrusion — without facial recognition or new hardware. ${BRAND.name} works on any IP camera, NVR, or DVR already installed at your school or college.` },
  { q: "How does automated attendance work without facial recognition?", a: `${BRAND.name} uses privacy-first, proxy-free people counting at classroom and lecture-hall entrances. The system counts entries and exits against scheduled timetables and correlates with your SIS — no biometrics, no identity matching, no PII stored. Institutions typically see 65%+ improvement in attendance accuracy versus manual registers.` },
  { q: "Does campus CCTV analytics work with our existing cameras?", a: `Yes. ${BRAND.name} connects to any IP camera, NVR, or DVR via RTSP or ONVIF — Hikvision, CP Plus, Dahua, Axis, and others common on Indian campuses. No camera replacement or dedicated attendance hardware is required.` },
  { q: "How is student privacy protected on campus?", a: `${BRAND.name} analyses behavioural patterns and events, not personal identities. No facial recognition, no biometric enrolment, no student PII in the analytics layer. Video can remain on-premise, access is encrypted and role-based, and the platform is designed to align with India's DPDP Act and institutional data policies.` },
  { q: "Can video analytics monitor exam integrity?", a: `Yes. ${BRAND.name} monitors exam halls for unauthorised movement, paper-sharing gestures, invigilator absence beyond thresholds, and students leaving seats during active papers. Real-time alerts with clip evidence go to exam controllers and security via WhatsApp — enabling intervention during the paper, not after.` },
  { q: "How does campus safety and incident detection work?", a: `AI models trained on campus scenarios detect fights, falls, smoke or fire indicators, weapon-like objects, and unusual gathering patterns in corridors and common areas. Security and admin teams receive instant clip-backed alerts — industry deployments report up to 40% fewer escalated incidents when teams act on real-time intelligence.` },
  { q: "Can it detect tailgating and unauthorized access?", a: `Yes. Entry gates, turnstiles, and staff-only doors are monitored for tailgating (one credential, multiple people), door-held-open events, and access outside permitted hours. Alerts include timestamped clips and gate IDs for security review.` },
  { q: "How long does deployment take on a campus?", a: `A single school or college block typically goes live in 7–14 days including site assessment, camera connection, zone configuration, and SIS integration testing. Multi-campus rollouts use configuration templates — 20+ campuses can be operational in 10–16 weeks.` },
  { q: "Can it scale across multiple campuses?", a: `Yes. ${BRAND.name} is cloud-native with a unified multi-campus dashboard. Principals, registrars, and security heads benchmark attendance compliance, incident rates, and camera uptime across all locations from one view.` },
  { q: "What integrations does campus video analytics support?", a: "Core integrations include Student Information Systems (SIS), Learning Management Systems (LMS), WhatsApp, Slack, MS Teams, SMS, Power BI, REST API, and webhooks. Camera connectivity supports Hikvision, CP Plus, Dahua, and any ONVIF NVR/DVR." },
  { q: "How does agentic AI differ from traditional campus security dashboards?", a: `Traditional systems require someone to watch screens or check dashboards. ${BRAND.name}'s agentic AI lets admins ask questions in plain English or Hindi ("How many students are in Block B right now?"), set monitoring rules once, and receive verified clip-backed alerts on WhatsApp automatically.` },
  { q: "Can the system monitor restricted zones like labs and server rooms?", a: `Yes. Restricted zones — chemistry labs, server rooms, staff lounges, exam paper storage — are configured with access schedules. Any entry outside permitted hours or without authorised occupancy triggers an instant alert with video evidence.` },
  { q: "How does crowding detection help during emergencies?", a: `Corridor and common-area cameras count occupancy in real time. When density exceeds safe thresholds — during assemblies, fire drills, or actual emergencies — the system alerts security and triggers evacuation workflow notifications. Deployments report up to 60% faster emergency response when teams have live occupancy data.` },
  { q: "Does it work for parking lots and perimeter security?", a: `Yes. Exterior cameras monitor gates, parking lots, and campus perimeters for after-hours intrusion, vehicle loitering, forced-entry attempts, and unusual gathering near boundaries — sending alerts before threats reach classrooms.` },
  { q: "What ROI can schools and colleges expect?", a: "Institutions typically see 40% fewer escalated safety incidents, 65% attendance accuracy improvement, 60% faster emergency response, and 96% camera uptime — with payback often within an academic year when manual security and attendance labour costs are factored in. Actual results vary by campus size and execution." },
  { q: "Is it compliant with India's DPDP Act for educational institutions?", a: `Yes. ${BRAND.name} is designed for DPDP alignment: no facial recognition, anonymised event data, on-premise processing options, role-based access, audit logs, and configurable retention policies — helping schools and colleges pass legal, IT, and board review.` },
];

const howSteps = [
  { n: "1", title: "Connect existing cameras", body: "Link campus IP cameras, NVR, or DVR via RTSP/ONVIF. No new hardware — works with Hikvision, CP Plus, Dahua, and any ONVIF device already on your premises." },
  { n: "2", title: "AI configures campus zones", body: "Computer vision models set classroom entry lines, exam-hall boundaries, restricted zones, corridor crowding thresholds, and perimeter rules customised to your campus layout." },
  { n: "3", title: "Real-time intelligence flows", body: "Attendance, safety incidents, access violations, and crowding data stream to your multi-campus dashboard. Cross-campus benchmarking from day one." },
  { n: "4", title: "Agents alert on WhatsApp", body: "Set rules in plain language. AI agents watch 24/7 and send clip-backed alerts to WhatsApp, Slack, or Teams the moment something needs attention." },
  { n: "5", title: "Integrate and scale", body: "Sync with your SIS and LMS. Replicate winning configurations across blocks, campuses, and academic terms." },
];

const howTones = ["brand", "brand", "violet", "signal", "signal"] as const;
const pillarText: Record<string, string> = {
  brand: "text-brand-600",
  signal: "text-signal-600",
  violet: "text-violet-500",
};
const pillarBar: Record<string, string> = {
  brand: "bg-brand-500",
  signal: "bg-signal-500",
  violet: "bg-violet-500",
};

const educationAsk = {
  eyebrow: "Agentic AI",
  title: "Talk to your campus cameras.",
  titleAccent: "Get answers.",
  sub: `Ask about any building or campus in plain language, set a monitoring rule once, and let ${BRAND.name} agents watch your school or college 24/7 — surfacing attendance, safety, exam integrity and access violations without anyone watching a screen.`,
  agentName: `${BRAND.name} Campus Agent`,
  online: "online",
  inputHint: "Ask about attendance, exams, safety, access…",
  exchanges: [
    {
      q: "What's the attendance rate in Block A classrooms this morning?",
      a: "Block A shows 94% present across 12 classrooms — Room 204 is at 78%, below the 85% threshold.",
      kind: "stat" as const,
      value: "94%",
      delta: "Block A · this morning",
    },
    {
      q: "Any unauthorized access at the science lab after hours?",
      a: "Yes — 1 after-hours entry at Science Lab B at 21:14. Clip sent to security head via WhatsApp.",
      kind: "clip" as const,
      note: "Lab B · 21:14 · 0:22",
    },
    {
      q: "Alert me if more than 40 people gather in the main corridor.",
      a: "Done. I'll monitor the corridor cameras and message you on WhatsApp the moment occupancy crosses 40.",
      kind: "alert" as const,
      note: "Alert created · WhatsApp · 3 corridor cameras",
    },
    {
      q: "Show exam integrity flags from Hall 3 today.",
      a: "Hall 3 had 2 integrity flags today — 1 invigilator absence (12 min) and 1 student movement during active paper. Clips attached.",
      kind: "clip" as const,
      note: "Hall 3 · 10:42 · 0:15",
    },
    {
      q: "Is the invigilator present in Exam Hall 2 right now?",
      a: "Yes — invigilator confirmed present in Hall 2 for 47 minutes. Supervisor coverage meets SOP.",
      kind: "stat" as const,
      value: "Present",
      note: "Hall 2 · 47 min coverage",
    },
  ],
  rail: [
    { tag: "ASK", title: "Ask in plain language", body: "Question any campus block in English or Hindi — attendance, exams, safety, crowding or access. No dashboards to learn." },
    { tag: "MONITOR", title: "Agents watch 24/7", body: "Set up monitoring once and agents watch every camera around the clock, detecting only the campus events that matter to you." },
    { tag: "ACT", title: "Close the loop", body: "Verified, clip-backed alerts land on WhatsApp, Slack or Teams — so principals and security act in the moment." },
  ],
};

const metrics = [
  { value: "40%", label: "fewer escalated incidents" },
  { value: "65%", label: "attendance accuracy improvement" },
  { value: "60%", label: "faster emergency response" },
  { value: "96%", label: "camera uptime" },
];

const capabilities = [
  { icon: "FOOTFALL", title: "Automated attendance (proxy-free)", body: "Privacy-first people counting at classroom and lecture-hall entrances — no facial recognition, no biometrics. Correlates entry counts with timetables and SIS records for accurate, automated attendance without proxy teachers or manual registers.", keywords: "automated attendance CCTV, proxy-free attendance schools, classroom attendance video analytics" },
  { icon: "SAFETY", title: "Campus safety & incident detection", body: "Real-time detection of fights, falls, smoke indicators, and unusual gathering patterns in corridors and common areas. Security teams receive instant clip-backed WhatsApp alerts — enabling intervention before incidents escalate.", keywords: "campus safety AI, school incident detection CCTV, college security video analytics" },
  { icon: "COMPLIANCE", title: "Exam integrity monitoring", body: "Monitors exam halls for unauthorised movement, paper-sharing gestures, invigilator absence, and students leaving seats during active papers. Exam controllers get real-time alerts with timestamped clip evidence.", keywords: "exam integrity monitoring AI, exam hall CCTV analytics, invigilation compliance video" },
  { icon: "INTRUSION", title: "Unauthorized access & tailgating", body: "Detects tailgating through gates and turnstiles, door-held-open events, and access attempts outside permitted hours. Every flag includes gate ID, timestamp, and video clip for security review.", keywords: "campus tailgating detection, unauthorized access school CCTV, gate security video analytics" },
  { icon: "ALERTS", title: "Restricted zone alerts", body: "Chemistry labs, server rooms, staff areas, and exam paper storage are monitored against access schedules. Any entry outside permitted hours triggers instant alerts to security and admin teams.", keywords: "restricted zone alert campus, lab access monitoring AI, school restricted area CCTV" },
  { icon: "HEATMAP", title: "Crowding in corridors & common areas", body: "Real-time occupancy monitoring in corridors, cafeterias, assembly halls, and playgrounds. Alerts fire when density exceeds safe thresholds — critical for emergency evacuation and daily crowd management.", keywords: "corridor crowding detection, campus occupancy monitoring, school crowd management AI" },
  { icon: "STORE_HOURS", title: "After-hours intrusion", body: "Classrooms, libraries, and administrative blocks are monitored outside school hours. Any unauthorised entry triggers instant clip-backed alerts — replacing periodic guard rounds with continuous AI coverage.", keywords: "after hours campus intrusion, school night security AI, college after-hours CCTV" },
  { icon: "UNATTENDED", title: "Invigilator & supervisor presence", body: "Verifies invigilator and supervisor coverage in exam halls and sensitive zones. Absence beyond configured thresholds triggers alerts to exam controllers — ensuring SOP compliance during every paper.", keywords: "invigilator presence monitoring, exam supervisor compliance AI, invigilation video analytics" },
  { icon: "ALERTS", title: "Emergency response acceleration", body: "Live occupancy data, incident detection, and perimeter alerts combine to accelerate emergency workflows. Security and admin teams receive coordinated WhatsApp notifications with location, clip evidence, and recommended actions.", keywords: "campus emergency response AI, school evacuation video analytics, emergency alert CCTV" },
  { icon: "PERIMETER", title: "Perimeter & gate security", body: "Exterior cameras monitor campus gates, boundaries, and parking areas for loitering, forced-entry attempts, vehicle anomalies, and after-hours approach — alerting security before threats reach buildings.", keywords: "campus perimeter security AI, school gate monitoring CCTV, college boundary video analytics" },
  { icon: "DWELL", title: "Classroom compliance & parking monitoring", body: "Tracks classroom occupancy against timetables, verifies scheduled sessions are in progress, and monitors parking lots for unauthorised vehicles and after-hours activity — all from existing cameras.", keywords: "classroom compliance monitoring, school parking lot CCTV analytics, campus parking security AI" },
  { icon: "AGENTIC", title: "Agentic AI — talk to your cameras", body: "Ask questions in plain English or Hindi. Set monitoring rules in one sentence. AI agents watch every campus camera 24/7, verify events, and send clip-backed alerts to WhatsApp automatically. Multi-campus dashboard included.", keywords: "agentic AI education analytics, conversational campus video analytics, school CCTV WhatsApp alerts" },
];

const useCases = [
  { title: "K-12 schools & academies", points: ["Automated classroom attendance", "Playground & corridor safety", "Parent pickup zone monitoring", "After-hours intrusion alerts"] },
  { title: "Colleges & universities", points: ["Lecture-hall occupancy tracking", "Exam hall integrity monitoring", "Hostel perimeter security", "Multi-campus benchmarking"] },
  { title: "Coaching & test-prep centres", points: ["Batch attendance automation", "Exam integrity enforcement", "Restricted material zone alerts", "Peak-hour crowding management"] },
  { title: "Residential & boarding campuses", points: ["Hostel after-hours monitoring", "Gate & perimeter security", "Common area crowding alerts", "Emergency evacuation support"] },
  { title: "International & private schools", points: ["DPDP-compliant privacy design", "Multi-building dashboard", "Invigilator SOP compliance", "Parking & visitor monitoring"] },
  { title: "University research campuses", points: ["Lab restricted-zone alerts", "Server room access monitoring", "After-hours intrusion detection", "SIS & LMS integration"] },
];

const comparisonRows = [
  { metric: "Attendance tracking", without: "Manual registers, proxy teachers, or RFID cards", with: "Automated, proxy-free, 65%+ accuracy on existing cameras" },
  { metric: "Campus safety", without: "Reactive — incidents discovered when reported or on footage review", with: "Real-time incident detection with instant clip-backed alerts" },
  { metric: "Exam integrity", without: "Trust-based invigilation; malpractice found after papers end", with: "Live monitoring of movement, sharing, and invigilator presence" },
  { metric: "Unauthorized access", without: "Guards at gates only; tailgating goes undetected", with: "AI detects tailgating, held-open doors, and after-hours entry" },
  { metric: "Crowding & emergencies", without: "No live occupancy data; evacuation relies on manual headcounts", with: "Real-time corridor density; 60% faster emergency response" },
  { metric: "Restricted zones", without: "Key-based access with no continuous monitoring", with: "24/7 zone monitoring with schedule-based alerts" },
  { metric: "After-hours security", without: "Periodic guard rounds; gaps between patrols", with: "Continuous AI monitoring of all buildings and perimeters" },
  { metric: "Invigilator compliance", without: "Spot checks; absence discovered mid-paper or after", with: "Automated presence verification with threshold alerts" },
  { metric: "Perimeter security", without: "Fencing and guards only; no proactive threat detection", with: "AI detects loitering, forced entry, and boundary breaches" },
  { metric: "Multi-campus visibility", without: "Siloed CCTV per campus; manual reporting", with: "Unified dashboard across all campuses in real time" },
  { metric: "Student privacy", without: "Facial recognition or biometric systems with PII risk", with: "No facial recognition; behavioural analysis only; DPDP aligned" },
  { metric: "Hardware required", without: "New attendance hardware, sensors, or biometric devices", with: "Works with existing CCTV — zero new hardware investment" },
  { metric: "Camera reliability", without: "Blind spots discovered when incidents occur", with: "96% uptime monitoring with proactive camera health alerts" },
];

const integrations = [
  "WhatsApp", "Slack", "MS Teams", "SMS & Email", "SIS", "LMS",
  "Moodle", "Google Classroom", "Power BI", "REST API", "Webhooks",
  "AWS", "Google Cloud", "Azure", "Hikvision", "CP Plus", "Dahua", "ONVIF NVR/DVR",
];

const related = [
  { label: "Retail video analytics", href: "/industries/retail-video-analytics", note: "Footfall & conversion" },
  { label: "Manufacturing video analytics", href: "/industries/manufacturing-video-analytics", note: "Safety & SOP compliance" },
  { label: "Pricing", href: "/pricing", note: "Per-camera plans" },
  { label: "Book a demo", href: "/contact", note: "See it on your cameras" },
];

const schema = [
  webPageSchema({ url: pageUrl, name: title, description, image: "/og/education-video-analytics.png" }),
  howToSchema("How education video analytics works", "Deploy AI video analytics on existing campus CCTV in 5 steps", howSteps),
  itemListSchema(
    "Education video analytics capabilities",
    capabilities.map((cap) => ({ name: cap.title, description: cap.body })),
  ),
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Industries", url: "/industries" },
    { name: "Education Video Analytics", url: path },
  ]),
];
---
<BaseLayout title={title} description={description} path={path} schema={schema}>

  <!-- ===================== HERO ===================== -->
  <section class="bg-grid relative overflow-hidden">
    <div class="glow-radial pointer-events-none absolute inset-0"></div>
    <div class="container-x relative grid items-center gap-12 py-16 lg:grid-cols-[1fr_1fr] lg:py-24">
      <div>
        <nav class="mb-6 flex items-center gap-2 text-xs text-faint" aria-label="Breadcrumb">
          <a href={localizePath("/", locale)} class="hover:text-ink">Home</a>
          <span>/</span>
          <a href={localizePath("/industries", locale)} class="hover:text-ink">Industries</a>
          <span>/</span>
          <span class="text-ink">Education</span>
        </nav>
        <span class="inline-flex items-center gap-2 rounded-full border border-line bg-surface px-3 py-1 eyebrow shadow-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-signal-500"></span>Education Video Analytics
        </span>
        <h1 class="mt-5 text-balance text-4xl font-semibold leading-[1.07] tracking-tight text-ink md:text-5xl lg:text-[3.4rem]">
          Turn every campus camera into a <span class="text-brand-600">safety & intelligence</span> engine
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
          {BRAND.name} transforms your existing CCTV into automated attendance, exam integrity monitoring, campus safety alerts, access control intelligence, and emergency response acceleration — no facial recognition, no new hardware. Agentic AI lets you ask questions in plain language and get WhatsApp alerts automatically.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={contact} size="lg">
            Book an education demo
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </Button>
          <Button href="#how-it-works" variant="secondary" size="lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            See how it works
          </Button>
        </div>
        <p class="mt-6 sys-tag text-faint">Works with any IP camera · Hikvision · CP Plus · Dahua · ONVIF</p>
      </div>

      <div class="relative">
        <div class="surface-card aspect-video overflow-hidden bg-mist">
          <img
            src="/images/industries/education/education-video-analytics-dashboard-hero.webp"
            alt="Education video analytics dashboard showing multi-campus attendance, safety alerts and exam integrity monitoring on existing CCTV"
            title="AI video analytics for education — real-time campus dashboard powered by existing school cameras"
            width="800"
            height="450"
            loading="eager"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== QUICK ANSWER (AEO/GEO/LLMO) ===================== -->
  <section class="container-x -mt-6 relative z-10 pb-12">
    <div class="surface-card p-6 md:p-8" data-answer>
      <div class="flex items-start gap-3">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        </span>
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-600">Quick answer — What is education video analytics?</h2>
          <p class="mt-2 text-base leading-relaxed text-ink">
            <strong>Education video analytics</strong> is AI software that turns existing campus CCTV cameras into operational intelligence tools. It automates attendance without facial recognition, monitors exam integrity, detects safety incidents, flags unauthorized access and tailgating, alerts on corridor crowding, and accelerates emergency response — all without new hardware. Indian schools, colleges, and multi-campus institutions use it to improve attendance accuracy by 65%, reduce escalated incidents by 40%, and respond to emergencies 60% faster. {BRAND.name} adds an agentic layer: ask questions in plain language, set monitoring rules once, and receive verified clip-backed alerts on WhatsApp automatically.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== OUTCOME METRICS ===================== -->
  <section class="container-x pb-14">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {metrics.map((m) => (
        <div class="surface-card p-5 text-center">
          <div class="bg-gradient-to-br from-brand-600 to-signal-600 bg-clip-text font-mono text-2xl font-bold text-transparent md:text-3xl">{m.value}</div>
          <div class="mt-1.5 text-xs text-muted">{m.label}</div>
        </div>
      ))}
    </div>
    <p class="mt-4 text-center text-xs text-faint">Figures are benchmarks for education video analytics deployments; actual results vary by campus size, camera coverage and execution.</p>
  </section>

  <AuthorityCitations citations={educationCitations} class="-mt-6" />

  <!-- ===================== WHAT IS (detailed) ===================== -->
  <section class="bg-mist">
    <div class="container-x py-16 md:py-24">
      <div class="mx-auto max-w-3xl">
        <span class="eyebrow">Understanding education video analytics</span>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">What is education video analytics and why are India's top schools adopting it?</h2>
        <div class="mt-8 space-y-6 text-base leading-relaxed text-muted">
          <p>
            Education video analytics is the application of <strong>computer vision and artificial intelligence</strong> to existing campus security cameras, transforming passive CCTV footage into actionable operational intelligence in real time. Unlike traditional surveillance that simply records for later review, modern AI video analytics for schools and colleges <em>processes</em> every frame as it happens — counting attendance, detecting incidents, monitoring exam halls, and flagging access violations automatically.
          </p>
          <p>
            The technology answers questions campus administrators have struggled with for decades: <strong>"Are students actually in class? Is the campus safe right now? Is exam integrity being maintained?"</strong> Manual attendance registers, proxy teachers, and trust-based invigilation leave gaps that video analytics closes — using cameras already installed for security, with no facial recognition and no new hardware.
          </p>
          <p>
            India's education sector is undergoing rapid digitisation — from CBSE and state-board compliance requirements to university NAAC accreditation and DPDP Act obligations. The convergence of affordable IP cameras on campuses, widespread CCTV adoption driven by safety mandates, and mature AI inference has created ideal conditions for campus video analytics adoption. Multi-campus school groups and university systems are increasingly deploying these platforms to unify security, attendance, and compliance visibility.
          </p>
          <p>
            {BRAND.name} takes this further with <strong>agentic AI video analytics</strong> — instead of dashboards security staff must check, AI agents watch your campus cameras 24/7 and proactively surface insights and alerts. Ask "What's the attendance rate in Block B this morning?" in plain English or Hindi and get an instant answer. Set a rule — "alert me if anyone enters the chemistry lab after 6 PM" — and the agent handles the rest, sending verified clip-backed notifications to WhatsApp.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== AGENTIC AI (education) ===================== -->
  <AskShopEye content={educationAsk} />

  <!-- ===================== CAPABILITIES GRID ===================== -->
  <section id="capabilities" class="container-x py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Complete campus analytics suite</span>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">Everything your existing cameras can tell you about your campus</h2>
      <p class="mt-4 text-muted">From automated attendance to exam integrity and perimeter security — every capability runs on your current CCTV, with privacy-first design and no facial recognition.</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {capabilities.map((cap, i) => {
        const tones = ["brand", "signal", "violet", "brand", "signal", "violet", "brand", "signal"];
        const tone = tones[i % tones.length];
        const chipClass = tone === "brand" ? "bg-brand-50 text-brand-600" : tone === "signal" ? "bg-signal-50 text-signal-600" : "bg-violet-50 text-violet-500";
        return (
          <div class="surface-card group relative flex flex-col p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-float)]">
            <span class={`flex h-12 w-12 items-center justify-center rounded-xl ${chipClass}`}>
              <CapabilityIcon tag={cap.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-base font-semibold text-ink">{cap.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{cap.body}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section id="how-it-works" class="bg-mist">
    <div class="container-x py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">Easy implementation</span>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">Works with your existing campus CCTV infrastructure</h2>
