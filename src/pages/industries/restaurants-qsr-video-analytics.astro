---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import CapabilityIcon from "../../components/CapabilityIcon.astro";
import StepIcon from "../../components/StepIcon.astro";
import AskShopEye from "../../components/AskShopEye.astro";
import ContactDemo from "../../components/ContactDemo.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import AuthorityCitations from "../../components/AuthorityCitations.astro";
import { restaurantCitations } from "../../lib/industry-citations";
import { BRAND, SITE_URL, type Locale } from "../../config";
import { resolveLocale, localizePath } from "../../i18n/utils";
import {
  webPageSchema,
  faqSchema,
  breadcrumbSchema,
  howToSchema,
  itemListSchema,
} from "../../lib/schema";

const locale: Locale = resolveLocale(Astro.currentLocale);
const path = "/industries/restaurants-qsr-video-analytics";
const pageUrl = new URL(localizePath(path, locale), SITE_URL).href;
const contact = localizePath("/contact", locale);

const title = `Restaurants & QSR Video Analytics for Premium Dining Chains | ${BRAND.name}`;
const description = `${BRAND.name} restaurant video analytics turns existing CCTV into covers and footfall intelligence, table turn-time optimisation, host and billing queue alerts, kitchen hygiene and FSSAI compliance monitoring, POS-integrated cash operations, guest service alerts, and loss prevention — no new hardware. Built for premium multi-outlet restaurants and national QSR chains across India.`;

const faqItems = [
  { q: "What is restaurant video analytics?", a: `Restaurant video analytics is AI software that processes existing dining-room, kitchen, and counter CCTV feeds in real time to track covers and footfall, table occupancy and turn-times, host and billing queues, kitchen hygiene SOPs, POS-integrated billing anomalies, guest service gaps, and loss prevention — without facial recognition or new hardware. ${BRAND.name} works on any IP camera, NVR, or DVR already installed at your outlets.` },
  { q: "Does it work with our existing restaurant cameras?", a: `Yes. ${BRAND.name} connects to any IP camera, NVR, or DVR via RTSP or ONVIF — Hikvision, CP Plus, Dahua, Axis, and others common in Indian restaurants and QSR chains. No camera replacement or dedicated sensors are required.` },
  { q: "Can video analytics integrate with our POS system?", a: `Yes. ${BRAND.name} integrates with Petpooja, Posist, Rista, LimeTray, and other Indian restaurant POS platforms. The system correlates camera events with billing transactions to flag voids without service, cash drawer anomalies, discount abuse, and settlement mismatches — especially valuable when owners are not at the counter.` },
  { q: "How does FSSAI and kitchen hygiene compliance monitoring work?", a: `${BRAND.name} uses kitchen cameras to monitor glove usage, hairnet compliance, hand-washing at designated stations, cross-contamination zones, and food-handling SOPs. Real-time alerts with clip evidence go to kitchen managers and area heads via WhatsApp — deployments typically see 50–70% improvement in hygiene SOP compliance.` },
  { q: "Can it track covers, footfall, and peak-hour dining patterns?", a: `Yes. Entry and dining-area cameras count covers and footfall by hour, day, and outlet. Heatmaps show table occupancy and dwell patterns so operations teams optimise staffing, reservations, and kitchen prep for lunch and dinner peaks across multi-outlet chains.` },
  { q: "How does table turn-time analytics improve revenue?", a: `${BRAND.name} monitors table occupancy duration, seating utilisation, and host stand wait times. When tables exceed turn-time thresholds or the host queue grows, floor managers receive instant alerts. Chains typically see 18–28% faster table turns when teams act on real-time seating intelligence.` },
  { q: "Does it monitor Swiggy and Zomato aggregator pickup handoffs?", a: `Yes. Dedicated pickup zones are monitored for handoff discipline — verifying order collection within SLA windows, flagging unattended aggregator bags, and alerting when pickup queues exceed thresholds. This reduces customer complaints and platform penalties across high-volume outlets.` },
  { q: "How is guest privacy protected in dining areas?", a: `${BRAND.name} analyses behavioural patterns and operational events, not guest identities. No facial recognition, no biometric enrolment, no guest PII in the analytics layer. Video can remain on-premise, access is encrypted and role-based, and the platform is designed to align with India's DPDP Act.` },
  { q: "Can it scale across multiple restaurant outlets?", a: `Yes. ${BRAND.name} is cloud-native with a unified multi-outlet dashboard. Brand heads, area managers, and operations leads benchmark covers, turn-times, hygiene compliance, and billing anomaly rates across all locations from one view.` },
  { q: "How long does deployment take at a restaurant outlet?", a: `A single premium dining or QSR outlet typically goes live in 7–14 days including site assessment, camera connection, zone configuration, and POS integration testing. Multi-outlet rollouts use configuration templates — 20+ outlets can be operational in 8–12 weeks.` },
  { q: "What loss prevention capabilities are included?", a: `${BRAND.name} monitors kitchen prep areas, bar counters, store rooms, and back-of-house zones for after-hours intrusion, unauthorised access, inventory movement anomalies, and suspicious activity patterns. Clip-backed alerts go to owners and loss-prevention teams via WhatsApp.` },
  { q: "How does agentic AI differ from traditional restaurant CCTV dashboards?", a: `Traditional systems require someone to watch screens or check dashboards. ${BRAND.name}'s agentic AI lets operators ask questions in plain English or Hindi ("Which tables have been occupied over 90 minutes?"), set monitoring rules once, and receive verified clip-backed alerts on WhatsApp automatically.` },
  { q: "Does it work for fine-dining chains and hotel F&B operations?", a: `Yes. ${BRAND.name} is built for premium multi-outlet restaurants, national QSR chains, hotel F&B outlets, and multi-brand restaurant groups — with configurable zones for host stands, private dining rooms, open kitchens, bars, and takeaway counters.` },
  { q: "What ROI can restaurant chains expect?", a: "Chains typically see 18–28% faster table turns, 25–40% shorter host and counter wait times, 50–70% kitchen and hygiene SOP compliance improvement, and 30–45% fewer billing anomalies flagged — with payback often within a fiscal year when labour, shrink, and revenue leakage are factored in. Actual results vary by outlet size and execution." },
];

const howSteps = [
  { n: "1", title: "Connect existing cameras", body: "Link dining-room, kitchen, counter, and back-of-house IP cameras, NVR, or DVR via RTSP/ONVIF. No new hardware — works with Hikvision, CP Plus, Dahua, and any ONVIF device already on your premises." },
  { n: "2", title: "AI configures restaurant zones", body: "Computer vision models set entry lines, table zones, host stand queues, kitchen hygiene boundaries, bar and store room perimeters, and pickup handoff areas customised to your outlet layout." },
  { n: "3", title: "Real-time intelligence flows", body: "Covers, turn-times, queue lengths, hygiene compliance, and billing anomaly data stream to your multi-outlet dashboard. Cross-outlet benchmarking from day one." },
  { n: "4", title: "Agents alert on WhatsApp", body: "Set rules in plain language. AI agents watch 24/7 and send clip-backed alerts to WhatsApp, Slack, or Teams the moment something needs attention." },
  { n: "5", title: "Integrate and scale", body: "Sync with your POS and aggregator platforms. Replicate winning configurations across outlets, cities, and brands." },
];

const howTones = ["brand", "brand", "violet", "signal", "signal"] as const;
const pillarText: Record<string, string> = {
  brand: "text-brand-600",
  signal: "text-signal-600",
  violet: "text-violet-500",
};
const pillarBar: Record<string, string> = {
  brand: "bg-brand-500",
  signal: "bg-signal-500",
  violet: "bg-violet-500",
};

const restaurantAsk = {
  eyebrow: "Agentic AI",
  title: "Talk to your restaurant cameras.",
  titleAccent: "Get answers.",
  sub: `Ask about any outlet or dining zone in plain language, set a monitoring rule once, and let ${BRAND.name} agents watch your restaurants 24/7 — surfacing covers, turn-times, hygiene gaps, billing anomalies and guest service issues without anyone watching a screen.`,
  agentName: `${BRAND.name} Restaurant Agent`,
  online: "online",
  inputHint: "Ask about covers, tables, queues, kitchen…",
  exchanges: [
    {
      q: "How many covers did we do at Bandra outlet during lunch today?",
      a: "Bandra logged 142 covers between 12:00–15:30 — 18% above last Tuesday's lunch. Peak hour was 13:15 with 38 concurrent diners.",
      kind: "stat" as const,
      value: "142",
      delta: "Bandra · lunch today",
    },
    {
      q: "Any tables occupied over 90 minutes right now?",
      a: "Yes — Table 14 has been occupied for 97 minutes. Floor manager alerted via WhatsApp with clip.",
      kind: "clip" as const,
      note: "Table 14 · 97 min · 0:18",
    },
    {
      q: "Alert me if the host queue exceeds 6 guests.",
      a: "Done. I'll monitor the host stand camera and message you on WhatsApp the moment the queue crosses 6.",
      kind: "alert" as const,
      note: "Alert created · WhatsApp · host stand cam",
    },
    {
      q: "Show kitchen hygiene flags from Andheri kitchen today.",
      a: "Andheri kitchen had 3 hygiene flags today — 1 glove non-compliance, 1 hairnet gap, 1 hand-wash station skip. Clips attached.",
      kind: "clip" as const,
      note: "Andheri kitchen · 14:22 · 0:12",
    },
    {
      q: "Any billing anomalies at the counter in the last hour?",
      a: "2 anomalies flagged — 1 void without table service and 1 cash drawer open beyond threshold. POS correlation attached.",
      kind: "stat" as const,
      value: "2 flags",
      note: "Counter · last 60 min",
    },
  ],
  rail: [
    { tag: "ASK", title: "Ask in plain language", body: "Question any outlet in English or Hindi — covers, tables, queues, kitchen hygiene or billing. No dashboards to learn." },
    { tag: "MONITOR", title: "Agents watch 24/7", body: "Set up monitoring once and agents watch every camera around the clock, detecting only the restaurant events that matter to you." },
    { tag: "ACT", title: "Close the loop", body: "Verified, clip-backed alerts land on WhatsApp, Slack or Teams — so floor managers and owners act in the moment." },
  ],
};

const metrics = [
  { value: "18–28%", label: "faster table turns" },
  { value: "25–40%", label: "shorter counter/host wait" },
  { value: "+50–70%", label: "kitchen & hygiene SOP compliance" },
  { value: "30–45%", label: "fewer billing anomalies flagged" },
];

const capabilities = [
  { icon: "FOOTFALL", title: "Covers & footfall analytics", body: "Real-time cover counts and footfall by hour, day, and outlet — entry lines and dining-area cameras track guest volume for staffing, prep, and revenue forecasting without new sensors or manual headcounts.", keywords: "restaurant covers analytics, dining footfall CCTV, peak hour restaurant video analytics" },
  { icon: "HEATMAP", title: "Table occupancy & turn-time analytics", body: "Heatmaps and dwell tracking for every table zone show occupancy duration, seating utilisation, and turn-time bottlenecks. Floor managers get alerts when tables exceed thresholds — accelerating revenue per seat.", keywords: "table turn time analytics, restaurant seating heatmap, table occupancy AI" },
  { icon: "QUEUE", title: "Host stand & billing queue alerts", body: "Monitors host stand, counter, and takeaway queues in real time. Alerts fire when wait times or queue depth exceed SOP limits — reducing walkaways and improving first-impression guest experience.", keywords: "restaurant queue monitoring, host stand wait time AI, billing counter queue alerts" },
  { icon: "UNATTENDED", title: "Guest unattended / service response alerts", body: "Detects tables with no staff interaction beyond configured thresholds, empty water glasses, and delayed order delivery patterns. Service managers receive clip-backed WhatsApp alerts to intervene before complaints escalate.", keywords: "guest service alert restaurant, table unattended detection, restaurant service response AI" },
  { icon: "COMPLIANCE", title: "Kitchen hygiene & FSSAI compliance", body: "Monitors glove usage, hairnet compliance, hand-washing stations, and cross-contamination zones against FSSAI-aligned SOPs. Kitchen managers get real-time alerts with timestamped clip evidence for audit readiness.", keywords: "FSSAI compliance video analytics, kitchen hygiene monitoring AI, restaurant food safety CCTV" },
  { icon: "SAFETY", title: "Kitchen SOP & food-handling monitoring", body: "Tracks food-handling workflows — raw vs cooked separation, temperature zone discipline, prep station coverage, and cook-line SOP adherence. Continuous monitoring replaces periodic kitchen audits with 24/7 visual compliance.", keywords: "kitchen SOP monitoring, food handling compliance AI, restaurant cook line video analytics" },
  { icon: "CASH_OPS", title: "POS-integrated billing & cash operations", body: "Correlates camera events with POS transactions to flag voids without service, discount abuse, cash drawer anomalies, and settlement mismatches. Critical for owners who cannot be at every counter.", keywords: "restaurant POS fraud detection, billing anomaly video analytics, cash operations CCTV" },
  { icon: "LOSS_PREVENTION", title: "Loss prevention — kitchen, bar & store room", body: "Monitors kitchen prep areas, bar counters, and store rooms for unauthorised access, inventory movement anomalies, and suspicious activity. Clip-backed alerts enable intervention before shrink becomes significant.", keywords: "restaurant loss prevention AI, bar inventory CCTV analytics, kitchen shrink video monitoring" },
  { icon: "COMPLIANCE", title: "Staff presence & uniform/grooming compliance", body: "Verifies staff coverage at host stands, counters, and dining floors against shift schedules. Uniform and grooming compliance checks ensure brand standards are maintained across every outlet.", keywords: "restaurant staff compliance monitoring, uniform grooming AI, floor staff presence video analytics" },
  { icon: "CONVERSION", title: "Kitchen pass & order-to-serve speed", body: "Tracks order pickup at the kitchen pass and time-to-serve from plating to table delivery. Bottlenecks in expo and runner workflows are flagged in real time — improving guest satisfaction and table turn speed.", keywords: "kitchen pass monitoring, order to serve speed AI, restaurant expo line video analytics" },
  { icon: "ALERTS", title: "Aggregator pickup & handoff discipline", body: "Monitors Swiggy, Zomato, and direct takeaway pickup zones for handoff SLAs, unattended order bags, and queue overflow. Reduces platform penalties and customer complaints at high-volume outlets.", keywords: "aggregator pickup monitoring, Swiggy Zomato handoff AI, restaurant takeaway queue analytics" },
  { icon: "AGENTIC", title: "Agentic AI — talk to your restaurant cameras", body: "Ask questions in plain English or Hindi. Set monitoring rules in one sentence. AI agents watch every restaurant camera 24/7, verify events, and send clip-backed alerts to WhatsApp automatically. Multi-outlet dashboard included.", keywords: "agentic AI restaurant analytics, conversational dining video analytics, restaurant CCTV WhatsApp alerts" },
];

const useCases = [
  { title: "Fine-dining chains", points: ["Table turn-time optimisation", "Guest service response alerts", "Private dining room monitoring", "Wine bar loss prevention"] },
  { title: "National QSR chains", points: ["Covers and peak-hour analytics", "Kitchen pass speed monitoring", "Counter queue management", "Multi-city benchmarking"] },
  { title: "Hotel F&B operations", points: ["Banquet and restaurant zone coverage", "Kitchen hygiene FSSAI compliance", "Staff uniform compliance", "After-hours back-of-house security"] },
  { title: "Premium café chains", points: ["Footfall and dwell analytics", "Counter wait-time alerts", "POS billing anomaly detection", "Aggregator pickup discipline"] },
  { title: "Multi-brand restaurant groups", points: ["Unified cross-brand dashboard", "Outlet-level KPI benchmarking", "Centralised loss prevention", "POS integration across brands"] },
];

const comparisonRows = [
  { metric: "Covers & footfall tracking", without: "Manual counts, POS estimates, or no hourly visibility", with: "Automated cover counts and peak-hour analytics on existing cameras" },
  { metric: "Table turn-times", without: "Floor managers guess; slow tables discovered late", with: "Real-time occupancy alerts; 18–28% faster table turns" },
  { metric: "Host & counter queues", without: "Walkaways before staff notice growing lines", with: "Instant queue alerts; 25–40% shorter wait times" },
  { metric: "Kitchen hygiene", without: "Periodic audits; FSSAI gaps found after inspections", with: "Continuous SOP monitoring; 50–70% compliance improvement" },
  { metric: "Billing & cash operations", without: "Fraud discovered during monthly reconciliation", with: "POS-correlated real-time anomaly flags at every counter" },
  { metric: "Guest service", without: "Complaints on review platforms before staff act", with: "Proactive unattended-table and service-delay alerts" },
  { metric: "Aggregator handoffs", without: "Cold food complaints and platform penalties", with: "Pickup zone SLA monitoring with clip evidence" },
  { metric: "Loss prevention", without: "Shrink found during inventory counts weeks later", with: "24/7 kitchen, bar, and store room monitoring" },
  { metric: "Staff compliance", without: "Spot checks; grooming gaps on busy shifts", with: "Automated uniform and presence verification" },
  { metric: "Multi-outlet visibility", without: "Siloed CCTV per outlet; manual area reports", with: "Unified dashboard across all outlets in real time" },
  { metric: "Guest privacy", without: "Facial recognition systems with identity risk", with: "No facial recognition; behavioural analysis only; DPDP aligned" },
  { metric: "Hardware required", without: "New sensors, queue tablets, or dedicated counters", with: "Works with existing CCTV — zero new hardware investment" },
];

const integrations = [
  "Petpooja", "Posist", "Rista", "LimeTray", "POS",
  "WhatsApp", "Slack", "MS Teams", "SMS & Email",
  "Swiggy", "Zomato", "Power BI", "REST API", "Webhooks",
  "Hikvision", "CP Plus", "Dahua", "ONVIF NVR/DVR",
];

const related = [
  { label: "Retail video analytics", href: "/industries/retail-video-analytics", note: "Footfall & conversion" },
  { label: "Manufacturing video analytics", href: "/industries/manufacturing-video-analytics", note: "Safety & SOP compliance" },
  { label: "Pricing", href: "/pricing", note: "Per-camera plans" },
  { label: "Book a demo", href: "/contact", note: "See it on your cameras" },
];

const schema = [
  webPageSchema({ url: pageUrl, name: title, description, image: "/og/restaurants-qsr-video-analytics.png" }),
  howToSchema("How restaurant video analytics works", "Deploy AI video analytics on existing restaurant CCTV in 5 steps", howSteps),
  itemListSchema(
    "Restaurant video analytics capabilities",
    capabilities.map((cap) => ({ name: cap.title, description: cap.body })),
  ),
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Industries", url: "/industries" },
    { name: "Restaurants & QSR Video Analytics", url: path },
  ]),
];
---
<BaseLayout title={title} description={description} path={path} schema={schema}>

  <!-- ===================== HERO ===================== -->
  <section class="bg-grid relative overflow-hidden">
    <div class="glow-radial pointer-events-none absolute inset-0"></div>
    <div class="container-x relative grid items-center gap-12 py-16 lg:grid-cols-[1fr_1fr] lg:py-24">
      <div>
        <nav class="mb-6 flex items-center gap-2 text-xs text-faint" aria-label="Breadcrumb">
          <a href={localizePath("/", locale)} class="hover:text-ink">Home</a>
          <span>/</span>
          <a href={localizePath("/industries", locale)} class="hover:text-ink">Industries</a>
          <span>/</span>
          <span class="text-ink">Restaurants & QSR</span>
        </nav>
        <span class="inline-flex items-center gap-2 rounded-full border border-line bg-surface px-3 py-1 eyebrow shadow-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-signal-500"></span>Restaurants & QSR Video Analytics
        </span>
        <h1 class="mt-5 text-balance text-4xl font-semibold leading-[1.07] tracking-tight text-ink md:text-5xl lg:text-[3.4rem]">
          Turn every restaurant camera into a <span class="text-brand-600">revenue & operations</span> engine
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
          {BRAND.name} transforms your existing CCTV into covers and footfall intelligence, table turn-time optimisation, host and billing queue alerts, kitchen hygiene and FSSAI compliance, POS-integrated cash operations, and loss prevention — no facial recognition, no new hardware. Agentic AI lets you ask questions in plain language and get WhatsApp alerts automatically.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={contact} size="lg">
            Book a restaurant demo
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </Button>
          <Button href="#how-it-works" variant="secondary" size="lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            See how it works
          </Button>
        </div>
        <p class="mt-6 sys-tag text-faint">Works with any IP camera · Hikvision · CP Plus · Dahua · ONVIF</p>
      </div>

      <div class="relative">
        <div class="surface-card aspect-video overflow-hidden lg:mt-8">
          <img
            src="/images/industries/restaurants-qsr/restaurants-qsr-video-analytics-dashboard-hero.webp"
            alt="Restaurant video analytics dashboard showing multi-outlet covers, table turn-times, host queue alerts and kitchen hygiene compliance on existing CCTV"
            title="AI video analytics for restaurants and QSR — real-time multi-outlet dashboard powered by existing cameras"
            width="1200"
            height="675"
            loading="eager"
            decoding="async"
            class="block h-auto w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== QUICK ANSWER (AEO/GEO/LLMO) ===================== -->
  <section class="container-x -mt-6 relative z-10 pb-12">
    <div class="surface-card p-6 md:p-8" data-answer>
      <div class="flex items-start gap-3">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        </span>
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-600">Quick answer — What is restaurant video analytics?</h2>
          <p class="mt-2 text-base leading-relaxed text-ink">
            <strong>Restaurant video analytics</strong> is AI software that turns existing dining-room, kitchen, and counter CCTV cameras into operational intelligence tools. It tracks covers and footfall, optimises table turn-times, alerts on host and billing queues, monitors kitchen hygiene and FSSAI compliance, flags POS-integrated billing anomalies, detects guest service gaps, and prevents loss in kitchen, bar, and store room areas — all without new hardware. Premium multi-outlet restaurants and national QSR chains in India use it to achieve 18–28% faster table turns, 25–40% shorter counter wait times, and 50–70% hygiene SOP compliance improvement. {BRAND.name} adds an agentic layer: ask questions in plain language, set monitoring rules once, and receive verified clip-backed alerts on WhatsApp automatically.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== OUTCOME METRICS ===================== -->
  <section class="container-x pb-14">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {metrics.map((m) => (
        <div class="surface-card p-5 text-center">
          <div class="bg-gradient-to-br from-brand-600 to-signal-600 bg-clip-text font-mono text-2xl font-bold text-transparent md:text-3xl">{m.value}</div>
          <div class="mt-1.5 text-xs text-muted">{m.label}</div>
        </div>
      ))}
    </div>
    <p class="mt-4 text-center text-xs text-faint">Figures are benchmarks for restaurant video analytics deployments; actual results vary by outlet size, camera coverage and execution.</p>
  </section>

  <AuthorityCitations citations={restaurantCitations} class="-mt-6" />

  <!-- ===================== WHAT IS (detailed) ===================== -->
  <section class="bg-mist">
    <div class="container-x py-16 md:py-24">
      <div class="mx-auto max-w-3xl">
        <span class="eyebrow">Understanding restaurant video analytics</span>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">What is restaurant video analytics and why are India's top dining chains adopting it?</h2>
        <div class="mt-8 space-y-6 text-base leading-relaxed text-muted">
          <p>
            Restaurant video analytics is the application of <strong>computer vision and artificial intelligence</strong> to existing security and operations cameras, transforming passive CCTV footage into actionable dining intelligence in real time. Unlike traditional surveillance that simply records for later review, modern AI video analytics for restaurants and QSR chains <em>processes</em> every frame as it happens — counting covers, tracking table occupancy, monitoring kitchen hygiene, and flagging billing anomalies automatically.
          </p>
          <p>
            The technology answers questions restaurant operators have struggled with for decades: <strong>"How many covers did we actually do? Why are tables turning slowly? Is the kitchen meeting FSSAI standards right now?"</strong> Manual floor walks, end-of-day POS reports, and periodic kitchen audits leave gaps that video analytics closes — using cameras already installed for security, with no facial recognition and no new hardware.
          </p>
          <p>
            India's premium dining and QSR sector is scaling rapidly — from multi-city fine-dining expansions to national QSR rollouts and hotel F&B portfolios. The convergence of affordable IP cameras in restaurants, widespread CCTV adoption driven by safety and compliance needs, and mature AI inference has created ideal conditions for restaurant video analytics adoption. Multi-outlet chains and restaurant groups are increasingly deploying these platforms to unify operations, hygiene, and revenue visibility.
          </p>
          <p>
            {BRAND.name} takes this further with <strong>agentic AI video analytics</strong> — instead of dashboards managers must check, AI agents watch your restaurant cameras 24/7 and proactively surface insights and alerts. Ask "Which tables have been occupied over 90 minutes?" in plain English or Hindi and get an instant answer. Set a rule — "alert me if the host queue exceeds 6 guests" — and the agent handles the rest, sending verified clip-backed notifications to WhatsApp.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== AGENTIC AI (restaurant) ===================== -->
  <AskShopEye content={restaurantAsk} />

  <!-- ===================== CAPABILITIES GRID ===================== -->
  <section id="capabilities" class="container-x py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Complete restaurant analytics suite</span>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">Everything your existing cameras can tell you about your restaurants</h2>
      <p class="mt-4 text-muted">From covers and footfall to kitchen hygiene and POS-integrated billing — every capability runs on your current CCTV, with privacy-first design and no facial recognition.</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {capabilities.map((cap, i) => {
        const tones = ["brand", "signal", "violet", "brand", "signal", "violet", "brand", "signal"];
        const tone = tones[i % tones.length];
        const chipClass = tone === "brand" ? "bg-brand-50 text-brand-600" : tone === "signal" ? "bg-signal-50 text-signal-600" : "bg-violet-50 text-violet-500";
        return (
          <div class="surface-card group relative flex flex-col p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-float)]">
            <span class={`flex h-12 w-12 items-center justify-center rounded-xl ${chipClass}`}>
              <CapabilityIcon tag={cap.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-base font-semibold text-ink">{cap.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{cap.body}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section id="how-it-works" class="bg-mist">
    <div class="container-x py-16 md:py-24">
