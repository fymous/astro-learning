---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import CapabilityIcon from "../../components/CapabilityIcon.astro";
import StepIcon from "../../components/StepIcon.astro";
import AskShopEye from "../../components/AskShopEye.astro";
import ContactDemo from "../../components/ContactDemo.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import AuthorityCitations from "../../components/AuthorityCitations.astro";
import { logisticsCitations } from "../../lib/industry-citations";
import { BRAND, SITE_URL, type Locale } from "../../config";
import { resolveLocale, localizePath } from "../../i18n/utils";
import {
  webPageSchema,
  faqSchema,
  breadcrumbSchema,
  howToSchema,
  itemListSchema,
} from "../../lib/schema";

const locale: Locale = resolveLocale(Astro.currentLocale);
const path = "/industries/logistics-video-analytics";
const pageUrl = new URL(localizePath(path, locale), SITE_URL).href;
const contact = localizePath("/contact", locale);

const title = `Logistics Video Analytics for Warehouses & DCs | ${BRAND.name}`;
const description = `${BRAND.name} logistics video analytics turns your existing CCTV into dock TAT tracking, package mishandling detection, PPE compliance, pilferage alerts, supervisor monitoring, warehouse intrusion detection, and SOP automation — no new hardware. Built for Indian warehousing and 3PL operations.`;

const faqItems = [
  { q: "What is logistics video analytics?", a: `Logistics video analytics is AI-powered software that processes existing warehouse and dock CCTV feeds in real time to measure truck turnaround time, detect package mishandling, monitor PPE compliance, flag open-box pilferage, verify supervisor presence, and alert on intrusion — turning passive security cameras into operational intelligence tools. ${BRAND.name} does this on any IP camera, NVR, or DVR without new hardware.` },
  { q: "How does AI video analytics reduce DEPS in warehouses?", a: `By detecting box throwing, standing or sitting on cartons, carrying boxes on shoulders instead of using pallets, and other mishandling behaviours in real time. ${BRAND.name} correlates damage events with dock bays, shifts, and handlers — enabling coaching and SOP enforcement that industry deployments associate with up to 38% lower DEPS (damaged/erroneous/pilfered shipments).` },
  { q: "Does logistics CCTV analytics work with my existing cameras?", a: `Yes. ${BRAND.name} connects to any IP camera, NVR, or DVR via standard RTSP or ONVIF protocols — Hikvision, CP Plus, Dahua, Axis, Bosch, and others. No camera replacement or new hardware is needed for dock, staging, or warehouse floor coverage.` },
  { q: "What data does a logistics video analytics platform collect?", a: "Core metrics include: dock and truck TAT (arrival, unload, load, departure), package mishandling event counts, PPE compliance scores, open-box and pilferage alerts, supervisor presence verification, crowding density by zone, intrusion events, warehouse open/close compliance, and MHE/forklift safety-zone violations. All data is behavioural — no facial recognition, no PII stored." },
  { q: "How is worker privacy protected in warehouse video analytics?", a: `${BRAND.name} analyses behavioural patterns and events, not personal identities. No biometric data or facial recognition is used. Video can remain on-premise, all access is encrypted and role-based, and the platform is designed to align with India's DPDP Act.` },
  { q: "What ROI can I expect from logistics video analytics?", a: "Industry benchmarks for warehouse video analytics indicate 38% lower DEPS, 65% improvement in SOP compliance, 24% faster dock turnaround time, and 96%+ camera uptime — with payback often within months. Actual results depend on warehouse format, shipment volume, and how operations teams act on alerts." },
  { q: "How long does deployment take at a warehouse or DC?", a: `Single-facility deployment typically takes 7–14 days including site assessment, camera connection via RTSP/ONVIF, AI model configuration for dock bays and handling zones, and testing. Multi-site rollouts accelerate after the first location using configuration templates — 20+ warehouses can be live in 10–14 weeks.` },
  { q: "Can it scale across multiple warehouses and 3PL sites?", a: `Yes. ${BRAND.name} is cloud-native and scales automatically. All facilities feed into a single centralized dashboard for cross-site benchmarking, regional reporting, and aggregate trend analysis across your logistics network.` },
  { q: "What types of logistics operations benefit most?", a: "High-throughput environments see the greatest impact: e-commerce fulfillment centres, FMCG distribution warehouses, 3PL hubs, cold-chain facilities, courier sort centres, and manufacturing warehouses with inbound/outbound docks. Any facility moving 500+ shipments daily benefits from dock TAT and handling compliance analytics." },
  { q: "How does agentic AI video analytics differ from traditional warehouse dashboards?", a: `Traditional analytics shows dashboards you must check. ${BRAND.name}'s agentic AI lets you ask questions in plain English or Hindi ('Which dock bay has the longest truck wait today?'), set monitoring rules once, and receive verified clip-backed alerts on WhatsApp or Slack automatically — no one needs to watch screens.` },
  { q: "Can video analytics detect box throwing and package mishandling?", a: `Yes. The platform uses pose and motion analysis to identify box throwing, dropping from height, standing or sitting on cartons, and carrying boxes on shoulders instead of using pallets. ${BRAND.name} sends real-time alerts with video clips to warehouse supervisors via WhatsApp.` },
  { q: "How does truck not covered detection work?", a: `${BRAND.name} monitors loading docks and yard cameras to verify that trucks are tarpaulin-covered or sealed per SOP before departure. When a loaded truck leaves a bay without proper cover, the system flags it instantly with a timestamped clip — preventing weather damage claims and compliance violations.` },
  { q: "Can the system detect pilferage from open boxes?", a: `Yes. AI monitors staging and sort zones for open cartons, unauthorised hand movements into packages, and cargo theft at dock handoffs. Open box alerts and pilferage detections fire in real time with clip evidence linked to the exact bay, shift, and timestamp for investigation.` },
  { q: "How does supervisor not present monitoring work?", a: `${BRAND.name} verifies supervisor presence in configured zones during critical operations — dock loading, high-value SKU handling, and shift handovers. When a zone requires supervisory oversight and no supervisor is detected beyond a threshold, alerts go to operations managers with photo evidence.` },
  { q: "Can video analytics monitor warehouse opening and closing?", a: `Yes. ${BRAND.name} automatically verifies on-time warehouse opening and closing — checking for staff presence, lights, shutter/door status, and predefined routines. Late opens and early closes are flagged to regional managers with photo evidence, replacing trust-based compliance with verified data across all facilities.` },
];

const howSteps = [
  { n: "1", title: "Connect existing cameras", body: "Link your IP cameras, NVR, or DVR via RTSP/ONVIF. No new hardware, no rip-and-replace — works with Hikvision, CP Plus, Dahua, and any ONVIF device across docks and warehouse floors." },
  { n: "2", title: "AI configures detections", body: "Computer vision models automatically set dock bay zones, handling areas, PPE checkpoints, intrusion perimeters, and compliance rules customised for your warehouse layout." },
  { n: "3", title: "Real-time intelligence flows", body: "Dock TAT, mishandling events, PPE scores, pilferage alerts, and crowding data stream to your centralised dashboard. Multi-site benchmarking from day one." },
  { n: "4", title: "Agents alert on WhatsApp", body: "Set rules in plain language. AI agents watch 24/7 and send clip-backed alerts to WhatsApp, Slack, or Teams the moment something needs attention." },
  { n: "5", title: "Optimise and scale", body: "Use data-driven insights to adjust dock scheduling, staffing, and SOP training. Replicate winning configurations across all warehouses." },
];

// Tone maps mirroring the homepage "How it works" section.
const howTones = ["brand", "brand", "violet", "signal", "signal"] as const;
const pillarText: Record<string, string> = {
  brand: "text-brand-600",
  signal: "text-signal-600",
  violet: "text-violet-500",
};
const pillarBar: Record<string, string> = {
  brand: "bg-brand-500",
  signal: "bg-signal-500",
  violet: "bg-violet-500",
};

// Logistics-focused agentic Q&A — reuses the homepage AskShopEye component.
const logisticsAsk = {
  eyebrow: "Agentic AI",
  title: "Talk to your cameras.",
  titleAccent: "Get answers.",
  sub: `Ask about any warehouse in plain language, set a monitoring rule once, and let ${BRAND.name} agents watch your docks and floors 24/7 — surfacing TAT, mishandling, PPE gaps and pilferage without anyone watching a screen.`,
  agentName: `${BRAND.name} Logistics Agent`,
  online: "online",
  inputHint: "Ask about dock TAT, box mishandling, truck idle, PPE…",
  exchanges: [
    {
      q: "Which dock bay has the longest truck wait right now?",
      a: "Bay 4 — truck MH-12-AB-4521 has been idle 47 minutes waiting for a forklift. Bay 2 cleared in 18 min (best today).",
      kind: "stat" as const,
      value: "47 min",
      delta: "Bay 4 · idle wait",
    },
    {
      q: "How many box throwing events in the sort zone today?",
      a: "6 box throwing detections today in Sort Zone B — up from 2 yesterday. Peak between 2 and 4 PM shift.",
      kind: "stat" as const,
      value: "6",
      note: "Sort Zone B · today",
    },
    {
      q: "Alert me when any truck leaves without tarpaulin cover.",
      a: "Done. I'll watch every dock exit camera and message you on WhatsApp the moment a loaded truck departs uncovered.",
      kind: "alert" as const,
      note: "Alert created · WhatsApp · 8 dock exits monitored",
    },
    {
      q: "Show PPE violations near the loading dock today.",
      a: "Flagged 4 PPE not worn events at Dock Bay 3 today — 3 missing hard hats, 1 missing safety vest. Here's the latest clip.",
      kind: "clip" as const,
      note: "Bay 3 · 11:34 · 0:22",
    },
    {
      q: "Is the supervisor present in the high-value staging area?",
      a: "Supervisor not present in High-Value Staging for 12 minutes — threshold is 5 min. Alert sent to Ops Manager at 14:08.",
      kind: "clip" as const,
      note: "Staging HV · 14:08 · 0:15",
    },
  ],
  rail: [
    { tag: "ASK", title: "Ask in plain language", body: "Question any warehouse in English or Hindi — dock TAT, mishandling, PPE, pilferage or intrusion. No dashboards to learn." },
    { tag: "MONITOR", title: "Agents watch 24/7", body: "Set up monitoring once and agents watch every camera around the clock, detecting only the logistics events that matter to you." },
    { tag: "ACT", title: "Close the loop", body: "Verified, clip-backed alerts land on WhatsApp, Slack or Teams — so dock and warehouse managers act in the moment." },
  ],
};

const metrics = [
  { value: "38%", label: "lower DEPS" },
  { value: "+65%", label: "SOP compliance" },
  { value: "24%", label: "faster dock TAT" },
  { value: "96%", label: "camera uptime" },
];

const capabilities = [
  { icon: "QUEUE", title: "Dock & truck TAT analytics", body: "Measure arrival-to-departure turnaround for every dock bay — idle truck time, unload duration, load completion, and departure delays. Benchmark bays, shifts, and carriers to cut dock TAT by up to 24%.", keywords: "dock turnaround time analytics, truck TAT warehouse video analytics, loading dock efficiency AI" },
  { icon: "SAFETY", title: "Box throwing & mishandling detection", body: "Real-time detection of box throwing, dropping from height, and rough handling that drives DEPS. Correlate events with bays, handlers, and shifts for targeted coaching — industry deployments report up to 38% lower DEPS.", keywords: "box throwing detection warehouse, package mishandling AI, DEPS reduction video analytics" },
  { icon: "COMPLIANCE", title: "PPE & MHE safety compliance", body: "Automated checks for hard hats, safety vests, and gloves in configured zones. MHE/forklift safety zones flag pedestrians in restricted paths and near-miss events — with clip-backed alerts to safety officers.", keywords: "warehouse PPE detection AI, forklift safety zone monitoring, MHE compliance video analytics" },
  { icon: "LOSS_PREVENTION", title: "Pilferage, open box & cargo theft", body: "Detect pilferage from open boxes, unauthorised hand movements into cartons, and cargo theft at dock handoffs. Open box alerts fire instantly with clip evidence for loss-prevention teams.", keywords: "warehouse pilferage detection, open box alert AI, cargo theft dock handoff monitoring" },
  { icon: "COMPLIANCE", title: "Supervisor not present monitoring", body: "Verify supervisor presence during critical operations — dock loading, high-value SKU handling, and shift handovers. Alerts fire when required oversight is missing beyond a configurable threshold.", keywords: "supervisor presence monitoring warehouse, SOP compliance video analytics, warehouse supervisor detection" },
  { icon: "INTRUSION", title: "Warehouse intrusion detection", body: "After-hours and restricted-zone intrusion alerts trigger instantly when anyone enters the warehouse floor, staging area, or high-value cage outside permitted hours — with clip-backed WhatsApp notifications to security.", keywords: "warehouse intrusion detection AI, after hours warehouse security, restricted zone alert logistics" },
  { icon: "HEATMAP", title: "Crowding detection", body: "Real-time density monitoring in sort zones, staging lanes, and dock aprons. Predictive crowding alerts help redeploy staff before bottlenecks slow throughput or create safety hazards.", keywords: "warehouse crowding detection, sort zone density analytics, logistics congestion monitoring" },
  { icon: "SAFETY", title: "Handling ergonomics & pallet compliance", body: "Detect standing or sitting on cartons, boxes carried on shoulders instead of pallets, and pallet-not-used violations. Enforce proper handling SOPs that protect inventory and reduce worker injury risk.", keywords: "standing on box detection, pallet not used alert, box on shoulder warehouse AI" },
  { icon: "PERIMETER", title: "Truck not covered alerts", body: "Monitor dock exits and yard cameras to verify trucks are tarpaulin-covered or sealed before departure. Uncovered departures trigger instant alerts — preventing weather damage and compliance violations.", keywords: "truck not covered detection, tarpaulin compliance warehouse, dock exit monitoring AI" },
  { icon: "ALERTS", title: "Fire, smoke & dock hazard detection", body: "Early fire and smoke detection in warehouse and dock areas. Combined with cargo theft monitoring at handoff points, the system provides a unified safety and loss-prevention layer across your facility.", keywords: "warehouse fire smoke detection AI, dock hazard monitoring, logistics safety video analytics" },
  { icon: "STORE_HOURS", title: "Warehouse open / close compliance", body: "Automated verification of on-time warehouse opening and closing routines — lights, shutters, doors, staff presence. Late opens and early closes are flagged instantly to regional managers with photo evidence.", keywords: "warehouse opening closing monitoring, warehouse open close compliance AI, DC operations automation" },
  { icon: "AGENTIC", title: "Agentic AI — talk to your cameras", body: "Ask questions in plain English or Hindi. Set monitoring rules in one sentence. AI agents watch every camera 24/7, verify events, and send clip-backed alerts to WhatsApp automatically. No dashboards to learn.", keywords: "agentic AI logistics analytics, conversational warehouse video analytics, logistics video analytics WhatsApp alerts" },
];

const useCases = [
  { title: "E-commerce fulfillment centres", points: ["Pick-path crowding alerts", "Sort-zone mishandling detection", "Dock TAT by carrier", "PPE compliance at loading bays"] },
  { title: "FMCG & distribution warehouses", points: ["Pallet handling SOP enforcement", "Open-box pilferage monitoring", "Multi-dock TAT benchmarking", "Supervisor presence at dispatch"] },
  { title: "3PL & contract logistics", points: ["Cross-client SOP compliance scoring", "Cargo theft at handoff points", "Truck coverage verification", "Multi-site regional dashboards"] },
  { title: "Cold chain & pharma logistics", points: ["Restricted-zone intrusion alerts", "Temperature-adjacent dock monitoring", "High-value cage supervision", "Warehouse open/close compliance"] },
  { title: "Courier & express sort hubs", points: ["Peak-shift crowding management", "Box throwing in sort lanes", "MHE safety zone enforcement", "Shift-handover supervisor checks"] },
  { title: "Manufacturing inbound/outbound", points: ["Raw material dock TAT", "Finished-goods staging compliance", "Forklift-pedestrian near-miss alerts", "After-hours perimeter intrusion"] },
];

const comparisonRows = [
  { metric: "Dock turnaround time", without: "Manual logs, gate timestamps, or no bay-level data", with: "Automated per-bay TAT — arrival, unload, load, departure on existing cameras" },
  { metric: "Package mishandling (DEPS)", without: "Discovered at delivery — root cause unknown", with: "Real-time box throwing and mishandling alerts with handler correlation" },
  { metric: "PPE compliance", without: "Periodic walk-through audits — gaps between checks", with: "Continuous automated PPE verification with instant clip-backed alerts" },
  { metric: "Pilferage & open boxes", without: "Found during inventory counts — days or weeks later", with: "Real-time open box and pilferage detection at staging and dock zones" },
  { metric: "Supervisor oversight", without: "Trust-based — no verification during critical shifts", with: "Automated supervisor presence checks with photo evidence" },
  { metric: "Warehouse intrusion", without: "After-the-fact footage review — incidents found next morning", with: "Instant restricted-zone and after-hours intrusion alerts" },
  { metric: "Crowding & bottlenecks", without: "Reactive — supervisors notice congestion after throughput drops", with: "Predictive density alerts before sort lanes and docks choke" },
  { metric: "Handling ergonomics", without: "No visibility into standing on boxes or shoulder-carry violations", with: "Automated pallet-not-used and improper-carry detection" },
  { metric: "Truck coverage", without: "Discovered when customer claims weather damage", with: "Real-time truck not covered alerts at every dock exit" },
  { metric: "Warehouse open/close", without: "Trust-based — no verification of on-time opening or closing", with: "Automated compliance checks with photo evidence to regional managers" },
  { metric: "Multi-site benchmarking", without: "Manual spreadsheets, inconsistent manual data", with: "Centralised dashboard across all warehouses in real time" },
  { metric: "Hardware required", without: "New sensors, RFID gates, dedicated dock cameras", with: "Works with existing CCTV — zero new hardware investment" },
  { metric: "Time to ROI", without: "12–18 months (traditional solutions)", with: "2–4 months; measurable DEPS and TAT gains within first quarter" },
];

const integrations = [
  "WhatsApp", "Slack", "MS Teams", "SMS & Email", "SAP EWM", "Oracle WMS",
  "Blue Yonder", "TMS Systems", "Power BI", "REST API", "Webhooks", "AWS",
  "Google Cloud", "Azure", "Hikvision", "CP Plus", "Dahua", "ONVIF NVR/DVR",
];

const related = [
  { label: "Retail video analytics", href: "/industries/retail-video-analytics", note: "Footfall & conversion" },
  { label: "Manufacturing video analytics", href: "/industries/manufacturing-video-analytics", note: "Plant floor & safety" },
  { label: "Pricing", href: "/pricing", note: "Per-camera plans" },
  { label: "Book a demo", href: "/contact", note: "See it on your cameras" },
];

const schema = [
  webPageSchema({ url: pageUrl, name: title, description, image: "/og/logistics-video-analytics.png" }),
  howToSchema("How logistics video analytics works", "Deploy AI video analytics on existing warehouse CCTV in 5 steps", howSteps),
  itemListSchema(
    "Logistics video analytics capabilities",
    capabilities.map((cap) => ({ name: cap.title, description: cap.body })),
  ),
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Industries", url: "/industries" },
    { name: "Logistics Video Analytics", url: path },
  ]),
];
---
<BaseLayout title={title} description={description} path={path} schema={schema}>

  <!-- ===================== HERO ===================== -->
  <section class="bg-grid relative overflow-hidden">
    <div class="glow-radial pointer-events-none absolute inset-0"></div>
    <div class="container-x relative grid items-center gap-12 py-16 lg:grid-cols-[1fr_1fr] lg:py-24">
      <div>
        <nav class="mb-6 flex items-center gap-2 text-xs text-faint" aria-label="Breadcrumb">
          <a href={localizePath("/", locale)} class="hover:text-ink">Home</a>
          <span>/</span>
          <a href={localizePath("/industries", locale)} class="hover:text-ink">Industries</a>
          <span>/</span>
          <span class="text-ink">Logistics</span>
        </nav>
        <span class="inline-flex items-center gap-2 rounded-full border border-line bg-surface px-3 py-1 eyebrow shadow-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-signal-500"></span>Logistics Video Analytics
        </span>
        <h1 class="mt-5 text-balance text-4xl font-semibold leading-[1.07] tracking-tight text-ink md:text-5xl lg:text-[3.4rem]">
          Turn every warehouse camera into a <span class="text-brand-600">dock & compliance</span> intelligence engine
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
          {BRAND.name} transforms your existing CCTV into dock TAT trackers, mishandling detectors, PPE monitors, pilferage alerts, and supervisor compliance AI — no new hardware, no rip-and-replace. Agentic AI lets you ask questions in plain language and get WhatsApp alerts automatically.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={contact} size="lg">
            Book a logistics demo
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </Button>
          <Button href="#how-it-works" variant="secondary" size="lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            See how it works
          </Button>
        </div>
        <p class="mt-6 sys-tag text-faint">Works with any IP camera · Hikvision · CP Plus · Dahua · ONVIF</p>
      </div>

      <div class="relative">
        <div class="surface-card overflow-hidden">
          <img
            src="/images/industries/logistics/logistics-video-analytics-dashboard-hero.webp"
            alt="Logistics video analytics dashboard showing real-time dock TAT tracking, package mishandling alerts, PPE compliance scores and warehouse crowding detection on existing CCTV cameras"
            title="AI video analytics for logistics — real-time warehouse dashboard powered by existing dock cameras"
            width="1200"
            height="655"
            loading="eager"
            decoding="async"
            class="block h-auto w-full"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== QUICK ANSWER (AEO/GEO/LLMO) ===================== -->
  <section class="container-x -mt-6 relative z-10 pb-12">
    <div class="surface-card p-6 md:p-8" data-answer>
      <div class="flex items-start gap-3">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        </span>
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-600">Quick answer — What is logistics video analytics?</h2>
          <p class="mt-2 text-base leading-relaxed text-ink">
            <strong>Logistics video analytics</strong> is AI software that turns existing warehouse and dock CCTV cameras into operational intelligence tools. It measures dock and truck turnaround time, detects package mishandling and box throwing, monitors PPE compliance, flags pilferage from open boxes, verifies supervisor presence, and alerts on warehouse intrusion — without new hardware. Indian 3PL and distribution operators use it to cut DEPS, accelerate dock TAT, and enforce SOPs from cameras they already own — with industry benchmarks pointing to 38% lower DEPS, 65% better SOP compliance, and 24% faster dock turnaround. {BRAND.name} adds an agentic layer: ask questions in plain language, set monitoring rules once, and receive verified clip-backed alerts on WhatsApp automatically.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== OUTCOME METRICS ===================== -->
  <section class="container-x pb-14">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {metrics.map((m) => (
        <div class="surface-card p-5 text-center">
          <div class="bg-gradient-to-br from-brand-600 to-signal-600 bg-clip-text font-mono text-2xl font-bold text-transparent md:text-3xl">{m.value}</div>
          <div class="mt-1.5 text-xs text-muted">{m.label}</div>
        </div>
      ))}
    </div>
    <p class="mt-4 text-center text-xs text-faint">Figures are industry benchmarks for logistics video analytics; actual results vary by warehouse format, shipment volume and execution.</p>
  </section>

  <AuthorityCitations citations={logisticsCitations} class="-mt-6" />

  <!-- ===================== WHAT IS (detailed) ===================== -->
  <section class="bg-mist">
    <div class="container-x py-16 md:py-24">
      <div class="mx-auto max-w-3xl">
        <span class="eyebrow">Understanding logistics video analytics</span>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">What is logistics video analytics and why do India's top warehouses use it?</h2>
        <div class="mt-8 space-y-6 text-base leading-relaxed text-muted">
          <p>
            Logistics video analytics is the application of <strong>computer vision and artificial intelligence</strong> to existing warehouse and dock security cameras, transforming passive CCTV footage into actionable operational intelligence in real time. Unlike traditional video surveillance that simply records for later review, modern AI video analytics for warehousing <em>processes</em> every frame as it happens — tracking dock TAT, detecting mishandling, monitoring PPE, flagging pilferage, and verifying SOP compliance automatically.
          </p>
          <p>
            The technology answers the fundamental question logistics operators have struggled with for decades: <strong>"What is actually happening on my dock and warehouse floor?"</strong> WMS and TMS systems track inventory and shipments digitally — but the physical handling, waiting, and compliance gaps between scan events remain invisible. Logistics video analytics brings that visibility to the physical layer, using the cameras that are already installed.
          </p>
          <p>
            India's logistics sector is expanding rapidly — e-commerce fulfillment, FMCG distribution, and 3PL networks are scaling into tier-2 and tier-3 cities where operational oversight becomes harder to maintain. The convergence of affordable IP cameras, widespread CCTV adoption, and mature AI inference engines has created ideal conditions for warehouse CCTV analytics adoption. Operators managing DEPS, dock congestion, and compliance gaps are increasingly adopting these platforms to compete on operational excellence.
          </p>
          <p>
            {BRAND.name} takes this further with <strong>agentic AI video analytics</strong> — instead of dashboards you have to check, AI agents watch your cameras 24/7 and proactively surface insights and alerts. Ask "Which dock bay has the longest truck wait today?" in plain English or Hindi and get an instant answer. Set a rule — "alert me if anyone throws a box" — and the agent handles the rest, sending verified clip-backed notifications to WhatsApp.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== AGENTIC AI (logistics) ===================== -->
  <AskShopEye content={logisticsAsk} />

  <!-- ===================== CAPABILITIES GRID ===================== -->
  <section id="capabilities" class="container-x py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Complete logistics analytics suite</span>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">Everything your existing cameras can tell you about your warehouses</h2>
      <p class="mt-4 text-muted">From dock TAT to pilferage prevention, every capability runs on your current CCTV — no new hardware needed.</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {capabilities.map((cap, i) => {
        const tones = ["brand", "signal", "violet", "brand", "signal", "violet", "brand", "signal"];
        const tone = tones[i % tones.length];
        const chipClass = tone === "brand" ? "bg-brand-50 text-brand-600" : tone === "signal" ? "bg-signal-50 text-signal-600" : "bg-violet-50 text-violet-500";
        return (
          <div class="surface-card group relative flex flex-col p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-float)]">
            <span class={`flex h-12 w-12 items-center justify-center rounded-xl ${chipClass}`}>
