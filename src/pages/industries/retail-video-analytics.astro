---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import CapabilityIcon from "../../components/CapabilityIcon.astro";
import StepIcon from "../../components/StepIcon.astro";
import AskShopEye from "../../components/AskShopEye.astro";
import ContactDemo from "../../components/ContactDemo.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { BRAND, SITE_URL, type Locale } from "../../config";
import { resolveLocale, localizePath } from "../../i18n/utils";
import {
  webPageSchema,
  faqSchema,
  breadcrumbSchema,
  howToSchema,
  itemListSchema,
} from "../../lib/schema";

const locale: Locale = resolveLocale(Astro.currentLocale);
const path = "/industries/retail-video-analytics";
const pageUrl = new URL(localizePath(path, locale), SITE_URL).href;
const contact = localizePath("/contact", locale);

const title = `Retail Video Analytics for Stores & Chains | ${BRAND.name}`;
const description = `${BRAND.name} retail video analytics turns your existing CCTV into footfall counters, conversion funnels, heatmaps, queue alerts, loss-prevention AI, cash operations monitoring, perimeter security, and customer engagement tracking — no new hardware. Built for Indian retail chains.`;

const faqItems = [
  { q: "What is retail video analytics?", a: `Retail video analytics is AI-powered software that processes existing CCTV feeds in real time to measure footfall, dwell time, conversion rates, queue length, and demographics — turning passive security cameras into business intelligence tools. ${BRAND.name} does this on any IP camera, NVR, or DVR without new hardware.` },
  { q: "How does AI video analytics for retail improve conversion rates?", a: `By identifying which store zones attract visitors but fail to convert, optimising staff placement based on real traffic, and detecting queue buildup before customers walk away. Industry benchmarks associate footfall-and-conversion analytics with a 14–22% conversion improvement when teams act on the insights.` },
  { q: "Does retail CCTV analytics work with my existing cameras?", a: `Yes. ${BRAND.name} connects to any IP camera, NVR, or DVR via standard RTSP or ONVIF protocols — Hikvision, CP Plus, Dahua, Axis, Bosch, and others. No camera replacement or new hardware is needed.` },
  { q: "What data does a retail video analytics platform collect?", a: "Core metrics include: entrance footfall counts, zone dwell time, zone-level conversion rates, checkout queue length and wait time, anonymous demographics (age/gender estimation), staff-to-customer coverage ratios, and SOP compliance scores. All data is anonymised — no facial recognition, no PII stored." },
  { q: "How is customer privacy protected?", a: `${BRAND.name} analyses behavioural patterns and events, not personal identities. No biometric data or facial recognition is used. Video can remain on-premise, all access is encrypted and role-based, and the platform is designed to align with India's DPDP Act.` },
  { q: "What ROI can I expect from retail video analytics?", a: "Industry benchmarks for retail video analytics indicate 14–22% conversion improvement, 20–35% reduction in queue wait times, and meaningful shrinkage reduction, with payback often within months. According to Omdia (2024), 86% of video analytics deployments achieve ROI within 12 months. Actual results depend on your store formats, footfall and how teams act on the insights." },
  { q: "How long does deployment take?", a: `Single-store deployment typically takes 5–10 days including site assessment, camera connection via RTSP/ONVIF, AI model configuration, and testing. Multi-store rollouts accelerate after the first location using configuration templates across similar formats — 50+ stores can be live in 8–12 weeks.` },
  { q: "Can it scale across hundreds of store locations?", a: `Yes. ${BRAND.name} is cloud-native and scales automatically. All locations feed into a single centralized dashboard for cross-store benchmarking, regional reporting, and aggregate trend analysis.` },
  { q: "What types of retail businesses benefit most?", a: "High-footfall environments see the greatest impact: fashion/apparel chains, supermarkets, electronics retailers, pharmacies, convenience stores, shopping malls, and multi-brand outlets. Any physical retail space with 50+ daily visitors benefits from footfall and conversion analytics." },
  { q: "How does agentic AI video analytics differ from traditional dashboards?", a: `Traditional analytics shows dashboards you must check. ${BRAND.name}'s agentic AI lets you ask questions in plain English or Hindi ('How many people visited Store 12 today?'), set monitoring rules once, and receive verified clip-backed alerts on WhatsApp or Slack automatically — no one needs to watch screens.` },
  { q: "What is footfall analytics in retail?", a: "Footfall analytics is the automated counting and analysis of people entering and moving through a retail store using camera-based computer vision. It measures total visitors, entry/exit patterns, peak hours, zone traffic, and correlates with POS data to calculate true conversion rates." },
  { q: "Can retail video analytics detect shoplifting?", a: `Yes. The platform uses behavioural anomaly detection to identify suspicious patterns — unusual dwell in high-shrinkage zones, concealment gestures, staff collusion indicators, and after-hours intrusion. ${BRAND.name} sends real-time alerts with video clips to security teams via WhatsApp.` },
  { q: "How does cash operations monitoring work?", a: `${BRAND.name} correlates every POS transaction event — voids, no-sale opens, refunds, register closures — with the corresponding camera feed in real time. When the system detects anomalies (void-after-tender, sweet-hearting, unusual refund patterns, or till-open-without-transaction), it flags them instantly with a timestamped video clip linked to the exact transaction for review.` },
  { q: "Can video analytics detect suspicious activity outside the store?", a: `Yes. ${BRAND.name}'s perimeter monitoring AI uses exterior and parking-lot cameras to detect loitering beyond configurable time thresholds, tailgating through access points, forced-entry attempts on shuttered entrances, and unusual gathering patterns — sending real-time clip-backed alerts to security teams before an incident reaches the store floor.` },
  { q: "How does customer-unattended detection improve sales?", a: `The system uses zone-level occupancy and staff-proximity analysis to identify when a customer has been browsing a service zone (electronics, jewellery, furniture) beyond a configured threshold without staff engagement. It sends an instant alert to the nearest available associate, measurably improving response times and conversion rates in high-involvement categories.` },
  { q: "Can the system monitor store opening and closing times?", a: `Yes. ${BRAND.name} automatically verifies on-time store opening and closing — checking for staff presence, lights, shutters, and predefined routines. Late opens and early closes are flagged to area managers with photo evidence, replacing trust-based compliance with verified data across all locations.` },
];

const howSteps = [
  { n: "1", title: "Connect existing cameras", body: "Link your IP cameras, NVR, or DVR via RTSP/ONVIF. No new hardware, no rip-and-replace — works with Hikvision, CP Plus, Dahua, and any ONVIF device." },
  { n: "2", title: "AI configures detections", body: "Computer vision models automatically set detection zones, entry/exit lines, queue thresholds, and compliance rules customised for your store layout." },
  { n: "3", title: "Real-time intelligence flows", body: "Footfall, conversion, dwell time, heatmaps, and queue data stream to your centralised dashboard. Multi-store benchmarking from day one." },
  { n: "4", title: "Agents alert on WhatsApp", body: "Set rules in plain language. AI agents watch 24/7 and send clip-backed alerts to WhatsApp, Slack, or Teams the moment something needs attention." },
  { n: "5", title: "Optimise and scale", body: "Use data-driven insights to adjust layouts, staffing, and merchandising. Replicate winning configurations across all locations." },
];

// Tone maps mirroring the homepage "How it works" section.
const howTones = ["brand", "brand", "violet", "signal", "signal"] as const;
const pillarText: Record<string, string> = {
  brand: "text-brand-600",
  signal: "text-signal-600",
  violet: "text-violet-500",
};
const pillarBar: Record<string, string> = {
  brand: "bg-brand-500",
  signal: "bg-signal-500",
  violet: "bg-violet-500",
};

// Retail-focused agentic Q&A — reuses the homepage AskShopEye component.
const retailAsk = {
  eyebrow: "Agentic AI",
  title: "Talk to your cameras.",
  titleAccent: "Get answers.",
  sub: "Ask about any store in plain language, set a monitoring rule once, and let ShopEye agents watch your retail floor 24/7 — surfacing footfall, conversion, queues and shrinkage without anyone watching a screen.",
  agentName: "ShopEye Retail Agent",
  online: "online",
  inputHint: "Ask about footfall, conversion, queues, shrinkage…",
  exchanges: [
    {
      q: "How many people visited the Andheri store today?",
      a: "1,284 visitors today at Andheri — up 12% versus yesterday, peaking between 6 and 8 PM.",
      kind: "stat" as const,
      value: "1,284",
      delta: "+12% vs yesterday",
    },
    {
      q: "What's the conversion rate in the footwear section this week?",
      a: "Footwear converted 31% of visitors this week — dwell is high but checkout queues are the main drop-off point.",
      kind: "stat" as const,
      value: "31%",
      note: "footwear · this week",
    },
    {
      q: "Alert me when any billing counter has more than 5 people waiting.",
      a: "Done. I'll watch every checkout camera and message you on WhatsApp the moment a queue crosses 5 people.",
      kind: "alert" as const,
      note: "Alert created · WhatsApp · 6 counters monitored",
    },
    {
      q: "Show suspected concealment near the electronics shelf today.",
      a: "Flagged 2 concealment events near electronics today — here's the most recent clip for your loss-prevention team.",
      kind: "clip" as const,
      note: "Aisle 3 · 15:48 · 0:18",
    },
    {
      q: "Any no-sale register opens at Store 7 today?",
      a: "Store 7 had 3 no-sale register opens today — all on Counter 2 during the 2–4 PM shift. Here's the clip for the latest one.",
      kind: "clip" as const,
      note: "Counter 2 · 15:22 · 0:12",
    },
  ],
  rail: [
    { tag: "ASK", title: "Ask in plain language", body: "Question any store in English or Hindi — footfall, conversion, queues, dwell or shrinkage. No dashboards to learn." },
    { tag: "MONITOR", title: "Agents watch 24/7", body: "Set up monitoring once and agents watch every camera around the clock, detecting only the retail events that matter to you." },
    { tag: "ACT", title: "Close the loop", body: "Verified, clip-backed alerts land on WhatsApp, Slack or Teams — so store and area managers act in the moment." },
  ],
};

const metrics = [
  { value: "14–22%", label: "conversion rate improvement" },
  { value: "20–35%", label: "queue wait-time reduction" },
  { value: "98%+", label: "footfall counting accuracy" },
  { value: "2–3 mo", label: "typical payback period" },
];

const capabilities = [
  { icon: "CONVERSION", title: "Conversion funnel analytics", body: "Correlate entrance counts with POS transactions to measure true visitor-to-buyer conversion. See the full funnel — Visitors → Interested → Interacted → Billed — and identify exactly where drop-off happens.", keywords: "retail conversion analytics, footfall to conversion funnel retail" },
  { icon: "HEATMAP", title: "In-store heatmaps & dwell time", body: "Visual heatmaps reveal which zones attract attention and which are dead spots. Dwell-time data shows how long shoppers engage with specific displays — a direct proxy for purchase intent.", keywords: "in-store heatmap analytics, dwell time analytics retail, retail heatmap analytics" },
  { icon: "QUEUE", title: "Queue management & wait-time alerts", body: "Real-time queue length monitoring at every checkout counter. Predictive alerts fire before lines grow — giving managers time to open counters and prevent walkaway.", keywords: "retail queue analytics, checkout wait time monitoring, queue management video analytics" },
  { icon: "LOSS_PREVENTION", title: "Loss prevention & shrinkage AI", body: "Behavioural anomaly detection identifies concealment, staff collusion, and after-hours intrusion. Cashier fraud detection catches voids, sweet-hearting, and register manipulation with clip evidence.", keywords: "retail loss prevention AI, shoplifting detection CCTV, cashier fraud detection" },
  { icon: "CASH_OPS", title: "Cash operations monitoring", body: "Real-time POS-to-video correlation flags no-sale register opens, void patterns, till shortages, and cash-handling SOP violations — with timestamped clip evidence for every flagged transaction.", keywords: "cash register monitoring AI, POS fraud detection retail, retail cash operations" },
  { icon: "INTRUSION", title: "In-store intrusion detection", body: "After-hours and restricted-zone intrusion alerts trigger instantly when anyone enters the store floor, stockroom, or server room outside permitted hours — with clip-backed WhatsApp notifications to security.", keywords: "retail store intrusion detection, after hours store security AI, restricted zone alert retail" },
  { icon: "PERIMETER", title: "Suspicious activity outside store", body: "AI monitors exterior and parking-lot cameras for loitering, tailgating, forced-entry attempts, and unusual gathering patterns around entrances — sending perimeter alerts before an incident reaches the store floor.", keywords: "suspicious activity detection outside store, retail perimeter security AI, store exterior monitoring" },
  { icon: "STORE_HOURS", title: "Store open / close compliance", body: "Automated verification of on-time store opening and closing routines — lights, shutters, staff presence. Late opens and early closes are flagged instantly to area managers with photo evidence.", keywords: "store opening closing time monitoring, retail store open close compliance, store operations automation" },
  { icon: "UNATTENDED", title: "Customer left unattended alerts", body: "Detects when a customer has been waiting in a zone or at a counter beyond a configured threshold without staff engagement — triggering an instant alert so the nearest associate can respond.", keywords: "customer unattended alert retail, staff response time retail AI, customer waiting detection" },
  { icon: "DEMOGRAPHICS", title: "Footfall counting & demographics", body: "Automated people counting at every entrance, exit, and zone with 98%+ accuracy — combined with privacy-safe age, gender, and group-size estimation (men/women/kids) to reveal your actual customer mix from cameras, not surveys.", keywords: "retail customer demographics, footfall counting demographics, people counting men women kids retail" },
  { icon: "COMPLIANCE", title: "Staff productivity & SOP compliance", body: "Track staff idle time, counter-presence, customer engagement rate, and response time alongside automated SOP checks for opening/closing routines, uniform compliance, and hygiene protocols — across every store, every shift.", keywords: "staff productivity monitoring retail, staff-customer ratio retail analytics, retail SOP compliance, retail staff idle time detection" },
  { icon: "AGENTIC", title: "Agentic AI — talk to your cameras", body: "Ask questions in plain English or Hindi. Set monitoring rules in one sentence. AI agents watch every camera 24/7, verify events, and send clip-backed alerts to WhatsApp automatically. No dashboards to learn.", keywords: "agentic AI retail analytics, conversational retail video analytics, retail video analytics WhatsApp alerts" },
];

const useCases = [
  { title: "Fashion & apparel chains", points: ["Fitting room conversion tracking", "Visual merchandising effectiveness", "Staff engagement scoring", "Peak-hour zone analysis"] },
  { title: "Supermarkets & grocery", points: ["Aisle traffic density", "Promotional display impact", "Checkout queue prediction", "Planogram compliance"] },
  { title: "Electronics & consumer goods", points: ["High-value display monitoring", "Demo station engagement", "Loss prevention hotspot alerts", "Staff response time to customers"] },
  { title: "Malls & shopping centres", points: ["Mall-wide footfall counting", "Tenant performance benchmarking", "Common area congestion alerts", "Event impact measurement"] },
  { title: "Pharmacy & convenience", points: ["Counter wait-time optimisation", "Staff scheduling by traffic", "After-hours security alerts", "Regulatory compliance verification"] },
  { title: "Quick commerce & dark stores", points: ["Pick & pack productivity", "Dispatch SLA tracking", "Rider bay utilisation", "Shrinkage detection"] },
];

const comparisonRows = [
  { metric: "Footfall counting", without: "Manual clickers, estimation, or no data at all", with: "Automated, real-time, 98%+ accuracy on existing cameras" },
  { metric: "Conversion rate", without: "Unknown — estimated from POS data alone", with: "Precise footfall-to-sale ratio; identify drop-off zones" },
  { metric: "Queue management", without: "Reactive — staff notice long lines after customers leave", with: "Predictive alerts 5–15 min before queues exceed thresholds" },
  { metric: "Store layout decisions", without: "Gut instinct, periodic surveys, or costly consultants", with: "Data-driven heatmaps and zone dwell-time analysis" },
  { metric: "Loss prevention", without: "After-the-fact footage review — find incidents days later", with: "Real-time anomaly detection with instant clip-backed alerts" },
  { metric: "Staffing optimisation", without: "Fixed schedules regardless of actual traffic patterns", with: "Dynamic — align staff presence to real-time footfall data" },
  { metric: "Cash operations", without: "End-of-day reconciliation; fraud discovered hours later", with: "Real-time POS-video correlation; instant clip-backed fraud alerts" },
  { metric: "Perimeter security", without: "Guards or no exterior monitoring at all", with: "AI detects loitering, forced entry, and after-hours approach automatically" },
  { metric: "Customer engagement", without: "No visibility into unattended customers or staff response", with: "Automatic alerts when customers wait beyond threshold without staff" },
  { metric: "Store open/close", without: "Trust-based — no verification of on-time opening or closing", with: "Automated compliance checks with photo evidence to area managers" },
  { metric: "Multi-store benchmarking", without: "Manual spreadsheets, inconsistent manual data", with: "Centralised dashboard across all locations in real time" },
  { metric: "Hardware required", without: "New sensors, counters, people-counting cameras", with: "Works with existing CCTV — zero new hardware investment" },
  { metric: "Time to ROI", without: "12–18 months (traditional solutions)", with: "2–3 months; 86% achieve ROI within 12 months (Omdia 2024)" },
];

const integrations = [
  "WhatsApp", "Slack", "MS Teams", "SMS & Email", "Shopify", "POS Systems",
  "SAP Retail", "Power BI", "REST API", "Webhooks", "AWS", "Google Cloud",
  "Azure", "Hikvision", "CP Plus", "Dahua", "ONVIF NVR/DVR",
];

const related = [
  { label: "QSR video analytics", href: "/industries", note: "Drive-thru & kitchen SOP" },
  { label: "Pricing", href: "/pricing", note: "Per-camera plans" },
  { label: "Product overview", href: "/product", note: "How the platform works" },
  { label: "Book a demo", href: "/contact", note: "See it on your cameras" },
];

const schema = [
  webPageSchema({ url: pageUrl, name: title, description, image: "/og/retail-video-analytics.png" }),
  howToSchema("How retail video analytics works", "Deploy AI video analytics on existing retail CCTV in 5 steps", howSteps),
  itemListSchema(
    "Retail video analytics capabilities",
    capabilities.map((cap) => ({ name: cap.title, description: cap.body })),
  ),
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Industries", url: "/industries" },
    { name: "Retail Video Analytics", url: path },
  ]),
];
---
<BaseLayout title={title} description={description} path={path} schema={schema}>

  <!-- ===================== HERO ===================== -->
  <section class="bg-grid relative overflow-hidden">
    <div class="glow-radial pointer-events-none absolute inset-0"></div>
    <div class="container-x relative grid items-center gap-12 py-16 lg:grid-cols-[1fr_1fr] lg:py-24">
      <div>
        <nav class="mb-6 flex items-center gap-2 text-xs text-faint" aria-label="Breadcrumb">
          <a href={localizePath("/", locale)} class="hover:text-ink">Home</a>
          <span>/</span>
          <a href={localizePath("/industries", locale)} class="hover:text-ink">Industries</a>
          <span>/</span>
          <span class="text-ink">Retail</span>
        </nav>
        <span class="inline-flex items-center gap-2 rounded-full border border-line bg-surface px-3 py-1 eyebrow shadow-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-signal-500"></span>Retail Video Analytics
        </span>
        <h1 class="mt-5 text-balance text-4xl font-semibold leading-[1.07] tracking-tight text-ink md:text-5xl lg:text-[3.4rem]">
          Turn every retail camera into a <span class="text-brand-600">conversion & intelligence</span> engine
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
          {BRAND.name} transforms your existing CCTV into footfall counters, conversion funnels, heatmaps, queue alerts, and loss-prevention AI — no new hardware, no rip-and-replace. Agentic AI lets you ask questions in plain language and get WhatsApp alerts automatically.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href={contact} size="lg">
            Book a retail demo
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </Button>
          <Button href="#how-it-works" variant="secondary" size="lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            See how it works
          </Button>
        </div>
        <p class="mt-6 sys-tag text-faint">Works with any IP camera · Hikvision · CP Plus · Dahua · ONVIF</p>
      </div>

      <div class="relative">
        <div class="surface-card aspect-[4/3] overflow-hidden">
          <img
            src="/images/industries/retail/retail-video-analytics-dashboard-hero.webp"
            alt="Retail video analytics dashboard showing real-time footfall counting, conversion funnel, heatmaps and queue detection on existing CCTV cameras"
            title="AI video analytics for retail — real-time dashboard powered by existing store cameras"
            width="800"
            height="600"
            loading="eager"
            decoding="async"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== QUICK ANSWER (AEO/GEO/LLMO) ===================== -->
  <section class="container-x -mt-6 relative z-10 pb-12">
    <div class="surface-card p-6 md:p-8" data-answer>
      <div class="flex items-start gap-3">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        </span>
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-600">Quick answer — What is retail video analytics?</h2>
          <p class="mt-2 text-base leading-relaxed text-ink">
            <strong>Retail video analytics</strong> is AI software that turns existing store CCTV cameras into business intelligence tools. It measures footfall, dwell time, zone conversion rates, queue length, and anonymous demographics in real time — without new hardware. Indian multi-site retail chains use it to lift in-store conversion, reduce queue abandonment, and cut shrinkage, all from cameras they already own — with industry benchmarks pointing to 14–22% conversion gains and 20–35% shorter queue waits. {BRAND.name} adds an agentic layer: ask questions in plain language, set monitoring rules once, and receive verified clip-backed alerts on WhatsApp automatically.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== OUTCOME METRICS ===================== -->
  <section class="container-x pb-14">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      {metrics.map((m) => (
        <div class="surface-card p-5 text-center">
          <div class="bg-gradient-to-br from-brand-600 to-signal-600 bg-clip-text font-mono text-2xl font-bold text-transparent md:text-3xl">{m.value}</div>
          <div class="mt-1.5 text-xs text-muted">{m.label}</div>
        </div>
      ))}
    </div>
    <p class="mt-4 text-center text-xs text-faint">Figures are industry benchmarks for retail video analytics; actual results vary by store format, footfall and execution.</p>
  </section>

  <!-- ===================== WHAT IS (detailed) ===================== -->
  <section class="bg-mist">
    <div class="container-x py-16 md:py-24">
      <div class="mx-auto max-w-3xl">
        <span class="eyebrow">Understanding retail video analytics</span>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">What is retail video analytics and why do India's top chains use it?</h2>
        <div class="mt-8 space-y-6 text-base leading-relaxed text-muted">
          <p>
            Retail video analytics is the application of <strong>computer vision and artificial intelligence</strong> to existing store security cameras, transforming passive CCTV footage into actionable business intelligence in real time. Unlike traditional video surveillance that simply records for later review, modern AI video analytics for retail <em>processes</em> every frame as it happens — counting people, mapping movement, measuring engagement, and detecting anomalies automatically.
          </p>
          <p>
            The technology answers the fundamental question physical retailers have struggled with for decades: <strong>"What are customers actually doing inside my store?"</strong> E-commerce has had click-stream analytics since the early 2000s — knowing exactly which pages shoppers visit, how long they stay, where they drop off, and what converts. Retail video analytics brings that same granularity to physical stores, using the cameras that are already installed.
          </p>
          <p>
            According to Grand View Research, the retail segment of the global video analytics market is growing at a <strong>CAGR of 25.6%</strong> and is projected to reach $37.84 billion by 2030. In India specifically, the convergence of affordable IP cameras, widespread CCTV adoption (driven by regulatory and insurance requirements), and mature AI inference engines has created ideal conditions for retail CCTV analytics adoption. Organised retail chains are increasingly adopting these platforms to compete with online retailers on data-driven decision making.
          </p>
          <p>
            {BRAND.name} takes this further with <strong>agentic AI video analytics</strong> — instead of dashboards you have to check, AI agents watch your cameras 24/7 and proactively surface insights and alerts. Ask "How many people visited the electronics section today?" in plain English or Hindi and get an instant answer. Set a rule — "alert me if queue exceeds 5 people" — and the agent handles the rest, sending verified clip-backed notifications to WhatsApp.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== AGENTIC AI (retail) ===================== -->
  <AskShopEye content={retailAsk} />

  <!-- ===================== CAPABILITIES GRID ===================== -->
  <section id="capabilities" class="container-x py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Complete retail analytics suite</span>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">Everything your existing cameras can tell you about your stores</h2>
      <p class="mt-4 text-muted">From footfall counting to loss prevention, every capability runs on your current CCTV — no new hardware needed.</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {capabilities.map((cap, i) => {
        const tones = ["brand", "signal", "violet", "brand", "signal", "violet", "brand", "signal"];
        const tone = tones[i % tones.length];
        const chipClass = tone === "brand" ? "bg-brand-50 text-brand-600" : tone === "signal" ? "bg-signal-50 text-signal-600" : "bg-violet-50 text-violet-500";
        return (
          <div class="surface-card group relative flex flex-col p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-float)]">
            <span class={`flex h-12 w-12 items-center justify-center rounded-xl ${chipClass}`}>
              <CapabilityIcon tag={cap.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-base font-semibold text-ink">{cap.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{cap.body}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ===================== HOW IT WORKS (homepage style) ===================== -->
  <section id="how-it-works" class="bg-mist">
    <div class="container-x py-16 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">Easy implementation</span>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">Works with your existing CCTV infrastructure</h2>
