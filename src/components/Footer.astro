---
import { BRAND } from "../config";
import { ui } from "../i18n/ui";
import { localizePath } from "../i18n/utils";
import type { Locale } from "../config";
import Logo from "./Logo.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];
const f = t.footer;
const year = new Date().getFullYear();

const columns = [
  { heading: f.productHeading, links: f.productLinks },
  { heading: f.resourcesHeading, links: f.resourcesLinks },
  { heading: f.companyHeading, links: f.companyLinks },
];
---
<footer class="border-t border-line bg-mist">
  <div class="container-x grid gap-10 py-14 md:grid-cols-2 lg:grid-cols-5">
    <div class="lg:col-span-2">
      <Logo />
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted">{f.tagline}</p>
      <div class="mt-5 flex gap-3">
        <a href={BRAND.social.linkedin} class="text-faint hover:text-ink" aria-label="LinkedIn" rel="me">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm6 0h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05 4.02 0 4.76 2.65 4.76 6.1V21h-4v-5.5c0-1.3 0-3-1.83-3s-2.1 1.43-2.1 2.9V21H9V9Z"/></svg>
        </a>
        <a href={BRAND.social.x} class="text-faint hover:text-ink" aria-label="X">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-7.5 8.6L23 22h-6.9l-5.4-7-6.2 7H1.4l8-9.2L1 2h7l4.9 6.5L18.9 2Zm-2.4 18h1.9L7.6 4H5.6l10.9 16Z"/></svg>
        </a>
        <a href={BRAND.social.youtube} class="text-faint hover:text-ink" aria-label="YouTube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.8-1.8C19.2 5 12 5 12 5s-7.2 0-8.8.5A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.8 1.8C4.8 19 12 19 12 19s7.2 0 8.8-.5a2.5 2.5 0 0 0 1.8-1.8C23 15.2 23 12 23 12Zm-13 3V9l5 3-5 3Z"/></svg>
        </a>
      </div>
    </div>

    {
      columns.map((col) => (
        <div>
          <h2 class="text-sm font-semibold text-ink">{col.heading}</h2>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={localizePath(link.href, locale)}
                  class="text-sm text-muted transition-colors hover:text-ink"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="border-t border-line">
    <div class="container-x flex flex-col items-center justify-between gap-3 py-6 text-xs text-faint sm:flex-row">
      <p>© {year} {BRAND.legalName}. {f.rights}</p>
      <p class="font-mono">{BRAND.city}, India · {BRAND.email}</p>
    </div>
  </div>
</footer>
