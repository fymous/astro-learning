)}
{tag === "CONVERSION" && (
  <svg {...c} class={className}><path d="M3 4h18l-7 8v6l-4 2v-8Z"/></svg>
)}
{tag === "QUEUE" && (
  <svg {...c} class={className}><path d="M5 22h14M5 2h14M17 22v-4.2a2 2 0 0 0-.6-1.4L12 12l-4.4 4.4a2 2 0 0 0-.6 1.4V22M7 2v4.2a2 2 0 0 0 .6 1.4L12 12l4.4-4.4a2 2 0 0 0 .6-1.4V2"/></svg>
)}
{tag === "DWELL" && (
  <svg {...c} class={className}><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
)}
{tag === "SAFETY" && (
  <svg {...c} class={className}><path d="M4 15a8 8 0 0 1 16 0"/><path d="M2 15h20v2a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1Z"/><path d="M10 7.4V4h4v3.4"/></svg>
