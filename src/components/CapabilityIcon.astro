---
interface Props {
  tag: string;
  class?: string;
}
const { tag, class: className = "" } = Astro.props;
const c = { width: 22, height: 22, viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": 1.8, "stroke-linecap": "round", "stroke-linejoin": "round" } as const;
---
{tag === "FOOTFALL" && (
