---
import { resolveLocale, localizePath } from "../i18n/utils";
import { homeContent } from "../content/home";
import { BRAND, type Locale } from "../config";

const locale: Locale = resolveLocale(Astro.currentLocale);
const c = homeContent[locale].contact;
const demoHref = localizePath("/contact", locale);
const whatsappNumber = BRAND.phone.replace(/[^0-9]/g, "");
---
<section id="get-started" class="relative overflow-hidden border-t border-line bg-gradient-to-b from-mist/70 via-canvas to-mist/50 scroll-mt-24">
  <div class="pointer-events-none absolute -left-24 top-10 h-80 w-80 rounded-full bg-brand-500/8 blur-3xl"></div>
  <div class="pointer-events-none absolute -right-24 bottom-0 h-80 w-80 rounded-full bg-signal-500/8 blur-3xl"></div>

  <div class="container-x relative py-16 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">{c.eyebrow}</span>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">{c.title}</h2>
      <p class="mx-auto mt-4 max-w-xl text-muted">{c.sub}</p>
    </div>

    <div class="mx-auto mt-12 grid max-w-5xl gap-6 lg:grid-cols-[1.25fr_1fr]">
      <!-- ============ MESSAGE FORM ============ -->
      <div class="surface-card p-7 md:p-9">
        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action={demoHref} class="space-y-5">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="block">
              <span class="mb-1.5 block text-sm font-medium text-ink">{c.form.name}<span class="text-danger-500">*</span></span>
              <input required name="name" type="text" autocomplete="name" class="field" />
            </label>
            <label class="block">
              <span class="mb-1.5 block text-sm font-medium text-ink">{c.form.email}<span class="text-danger-500">*</span></span>
              <input required name="email" type="email" autocomplete="email" class="field" />
            </label>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="block">
              <span class="mb-1.5 block text-sm font-medium text-ink">{c.form.phone}<span class="text-danger-500">*</span></span>
              <input required name="phone" type="tel" autocomplete="tel" class="field" />
            </label>
            <label class="block">
              <span class="mb-1.5 block text-sm font-medium text-ink">{c.form.company}</span>
              <input name="company" type="text" autocomplete="organization" class="field" />
            </label>
          </div>

          <label class="block">
            <span class="mb-1.5 block text-sm font-medium text-ink">{c.form.message}</span>
            <textarea name="message" rows="4" class="field resize-none"></textarea>
          </label>

          <button type="submit" class="group inline-flex w-full items-center justify-center gap-2 rounded-full bg-gradient-to-r from-brand-600 to-signal-600 px-7 py-3.5 font-semibold text-white shadow-sm transition-transform hover:-translate-y-0.5 sm:w-auto">
            {c.form.submit}
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </button>
          <p class="text-xs leading-relaxed text-faint">{c.form.consent}</p>
        </form>
      </div>

      <!-- ============ DEMO PANEL ============ -->
      <div class="relative overflow-hidden rounded-[var(--radius-card)] bg-brand-800 p-7 text-white shadow-[var(--shadow-float)] md:p-9">
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand-800 via-brand-700 to-brand-600"></div>
        <div class="bg-grid pointer-events-none absolute inset-0 opacity-10"></div>
        <div class="pointer-events-none absolute -right-16 -top-20 h-60 w-60 rounded-full bg-brand-400/25 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-20 -left-12 h-56 w-56 rounded-full bg-signal-500/15 blur-3xl"></div>

        <div class="relative">
          <span class="inline-flex items-center gap-2 rounded-full bg-white/12 px-3 py-1 font-mono text-[0.7rem] font-semibold uppercase tracking-wider text-white ring-1 ring-white/20">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18M8 2.5v4M16 2.5v4"/></svg>
            30 min
          </span>
          <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">{c.demo.title}</h3>
          <p class="mt-2 text-white/80">{c.demo.sub}</p>

          <ul class="mt-6 space-y-3">
            {c.demo.points.map((pt) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-signal-400/25 text-signal-400">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                <span class="text-sm text-white/90">{pt}</span>
              </li>
            ))}
          </ul>

          <a href={demoHref} class="group mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-white px-7 py-3.5 font-semibold text-brand-700 shadow-sm transition-transform hover:-translate-y-0.5">
            {c.demo.cta}
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>

          <div class="mt-7 border-t border-white/15 pt-5">
            <p class="font-mono text-[0.7rem] uppercase tracking-wider text-white/60">{c.demo.or}</p>
            <div class="mt-3 space-y-2.5">
              <a href={`mailto:${BRAND.email}`} class="flex items-center gap-3 text-sm text-white/90 transition-colors hover:text-white">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/12">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                </span>
                <span>{c.demo.emailLabel} · {BRAND.email}</span>
              </a>
              <a href={`https://wa.me/${whatsappNumber}`} class="flex items-center gap-3 text-sm text-white/90 transition-colors hover:text-white">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/12">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.5 8.5 0 0 1-12.5 7.5L3 21l2-5.5A8.5 8.5 0 1 1 21 11.5Z"/></svg>
                </span>
                <span>{c.demo.whatsappLabel} · {BRAND.phone}</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
