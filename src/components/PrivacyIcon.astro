---
interface Props {
  icon: string;
  size?: number;
}
const { icon, size = 22 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {icon === "no-id" && (
    <>
      <path d="M2 2l20 20" />
      <path d="M6.7 6.7A8.6 8.6 0 0 0 1 12s4 7 11 7a9.7 9.7 0 0 0 4.2-.9" />
      <path d="M10 5.1A9.4 9.4 0 0 1 12 5c7 0 11 7 11 7a17 17 0 0 1-2.2 3" />
      <path d="M9.9 9.9a3 3 0 0 0 4.2 4.2" />
    </>
  )}
  {icon === "onprem" && (
    <>
      <rect x="3" y="4" width="18" height="6" rx="1.5" />
      <rect x="3" y="14" width="18" height="6" rx="1.5" />
      <path d="M7 7h.01M7 17h.01" />
    </>
  )}
  {icon === "lock" && (
    <>
      <rect x="4" y="11" width="16" height="10" rx="2" />
      <path d="M8 11V7a4 4 0 0 1 8 0v4" />
      <path d="M12 15v2" />
    </>
  )}
  {icon === "rbac" && (
    <>
      <circle cx="9" cy="8" r="3.2" />
      <path d="M3 20a6 6 0 0 1 12 0" />
      <path d="M17.5 11.5 21 8M21 8h-3M21 8v3" />
      <path d="M18 14.5 21 17.5M21 17.5l-2.6.4M21 17.5l-.4-2.6" />
    </>
  )}
  {icon === "audit" && (
    <>
      <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
      <path d="M14 3v5h5" />
      <path d="m9 14 1.8 1.8L14 12.5" />
    </>
  )}
  {icon === "retention" && (
    <>
      <rect x="3" y="4.5" width="18" height="16" rx="2" />
      <path d="M3 9h18M8 2.5v4M16 2.5v4" />
      <circle cx="12" cy="14.5" r="3" />
      <path d="M12 13v1.7l1.1.8" />
    </>
  )}
</svg>
