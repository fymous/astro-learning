---
interface Props {
  icon: string;
  class?: string;
}
const { icon, class: className = "" } = Astro.props;
const common = { width: 20, height: 20, viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": 1.9, "stroke-linecap": "round", "stroke-linejoin": "round" } as const;
---
{icon === "insight" && (
  <svg {...common} class={className}><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M18.4 5.6 17 7M7 17l-1.4 1.4"/><circle cx="12" cy="12" r="3.2"/></svg>
)}
{icon === "revenue" && (
  <svg {...common} class={className}><path d="M3 17l6-6 4 4 7-7"/><path d="M17 8h4v4"/></svg>
)}
{icon === "compliance" && (
  <svg {...common} class={className}><path d="M12 3 4 6v5c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6Z"/><path d="m9 12 2 2 4-4"/></svg>
)}
{icon === "cost" && (
  <svg {...common} class={className}><path d="M3 7l6 6 4-4 7 7"/><path d="M21 16v-4h-4"/></svg>
)}
{icon === "speed" && (
  <svg {...common} class={className}><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>
)}
