---
import { resolveLocale } from "../i18n/utils";
import { homeContent } from "../content/home";
import IndustryIcon from "./IndustryIcon.astro";
import type { Locale } from "../config";

const locale: Locale = resolveLocale(Astro.currentLocale);
const a = homeContent[locale].liveAlerts;

const railTone = ["brand", "violet", "signal"] as const;
const railClass: Record<string, string> = {
  brand: "bg-brand-50 text-brand-600",
  violet: "bg-violet-50 text-violet-500",
  signal: "bg-signal-50 text-signal-600",
};

const toneClasses: Record<string, { bg: string; text: string; border: string; chip: string }> = {
  brand: { bg: "bg-brand-50", text: "text-brand-600", border: "border-brand-500/30", chip: "bg-brand-500" },
  warn: { bg: "bg-warn-50", text: "text-warn-500", border: "border-warn-500/30", chip: "bg-warn-500" },
  danger: { bg: "bg-danger-50", text: "text-danger-500", border: "border-danger-500/30", chip: "bg-danger-500" },
  signal: { bg: "bg-signal-50", text: "text-signal-600", border: "border-signal-500/30", chip: "bg-signal-500" },
};
---
<section id="alerts" class="bg-canvas">
  <div class="container-x grid items-center gap-12 py-16 md:py-24 lg:grid-cols-[1.05fr_0.95fr]">
    <!-- LEFT: Live operations panel -->
    <div class="surface-card overflow-hidden">
      <!-- Header bar -->
      <div class="flex items-center justify-between border-b border-line bg-mist px-5 py-3.5">
        <div class="flex items-center gap-3">
          <span class="flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-warn-500 to-danger-500">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
          </span>
          <div>
            <div class="text-sm font-semibold text-ink">{a.panel.title}</div>
            <div class="flex items-center gap-1.5 text-xs text-signal-600">
              <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-signal-500"></span>{a.panel.sites}
            </div>
          </div>
        </div>
        <span class="sys-tag text-faint">LIVE</span>
      </div>

      <!-- Scenes -->
      <div class="divide-y divide-line bg-canvas">
        {
          a.panel.scenes.map((scene) => {
            const tone = toneClasses[scene.alert.tone];
            return (
              <div class="p-5 md:p-6">
                <div class="flex items-center gap-2.5">
                  <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-mist text-brand-600">
                    <IndustryIcon slug={scene.industryIcon} size={16} />
                  </span>
                  <span class="text-sm font-semibold text-ink">{scene.site}</span>
                </div>

                {scene.kind === "rules" && scene.rules && (
                  <>
                    <div class="mt-4 sys-tag text-faint">{scene.rulesLabel}</div>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {scene.rules.map((rule) => {
                        const rt = toneClasses[rule.tone];
                        return (
                          <div class={`flex items-center gap-2 rounded-lg border ${rt.border} bg-surface px-3 py-2`}>
                            <span class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-md ${rt.bg} ${rt.text}`}>
                              {rule.icon === "queue" && (
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" />
                                </svg>
                              )}
                              {rule.icon === "shield" && (
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                  <path d="M12 3 4 6v6c0 5 3.4 8.5 8 11 4.6-1.5 8-5 8-11V6Z" /><path d="M12 8v4M12 16h.01" />
                                </svg>
                              )}
                              {rule.icon === "clock" && (
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                  <circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" />
                                </svg>
                              )}
                            </span>
                            <div>
                              <div class="text-xs font-semibold leading-tight text-ink">{rule.title}</div>
                              <div class="sys-tag text-faint">{rule.scope}</div>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </>
                )}

                {scene.kind === "counters" && scene.counters && (
                  <>
                    <div class="mt-4 sys-tag text-faint">{scene.countersLabel}</div>
                    <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
                      {scene.counters.map((cn) => (
                        <div class="rounded-lg border border-line bg-surface p-3">
                          <div class="sys-tag truncate text-faint">{cn.label}</div>
                          <div class="mt-1 flex items-end justify-between gap-1">
                            <span class="font-mono text-2xl font-bold leading-none text-ink">{cn.value}</span>
                            {cn.delta && <span class="sys-tag text-signal-600">{cn.delta}</span>}
                          </div>
                        </div>
                      ))}
                    </div>
                  </>
                )}

                <!-- Alert that fired -->
                <div class={`mt-4 flex items-center gap-3 rounded-xl border ${tone.border} ${tone.bg} p-3.5`}>
                  <span class={`flex h-9 w-9 shrink-0 items-center justify-center rounded-lg ${tone.chip}`}>
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">
                      <path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" />
                    </svg>
                  </span>
                  <div class="min-w-0 flex-1">
                    <div class={`sys-tag ${tone.text}`}>
                      {scene.alert.chip} · {scene.alert.time}
                    </div>
                    <div class="truncate text-sm font-semibold text-ink">{scene.alert.title}</div>
                    <div class="truncate text-xs text-muted">{scene.alert.body}</div>
                  </div>
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-signal-500">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="#fff"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2Zm5.3 13.9c-.2.6-1.2 1.1-1.7 1.2-.5.1-1 .1-1.6-.1-.4-.1-.9-.3-1.5-.5-2.6-1.1-4.3-3.7-4.4-3.9-.1-.2-1-1.4-1-2.6s.6-1.8.9-2.1c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.7 1.7c.1.2.1.4 0 .5l-.3.4-.3.3c-.1.1-.3.3-.1.5.1.3.6 1 1.3 1.6.9.8 1.6 1 1.9 1.1.2.1.4.1.5-.1l.6-.7c.2-.2.3-.2.5-.1l1.6.8c.2.1.4.2.4.3.1.1.1.5 0 1Z"/></svg>
                  </span>
                </div>
              </div>
            );
          })
        }
      </div>

      <!-- Add rule footer -->
      <div class="border-t border-line bg-mist p-3">
        <div class="flex items-center gap-2 rounded-full border border-line-strong bg-canvas py-2 pl-4 pr-2">
          <span class="flex-1 truncate text-sm text-faint">{a.panel.addRule}</span>
          <span class="flex h-8 w-8 items-center justify-center rounded-full bg-warn-500">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
          </span>
        </div>
      </div>
    </div>

    <!-- RIGHT: Copy + rail -->
    <div>
      <span class="eyebrow">{a.eyebrow}</span>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">
        {a.title} <span class="text-warn-500">{a.titleAccent}</span>
      </h2>
      <p class="mt-4 max-w-md text-muted">{a.sub}</p>

      <ol class="mt-8 space-y-3">
        {
          a.rail.map((step, i) => (
            <li class="surface-card flex gap-4 p-5">
              <span class={`sys-tag mt-0.5 flex h-7 shrink-0 items-center rounded px-2 ${railClass[railTone[i]]}`}>
                {step.tag}
              </span>
              <div>
                <h3 class="text-base font-semibold text-ink">{step.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-muted">{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
