---
import { BRAND } from "../config";
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<span class={`inline-flex items-center gap-2.5 ${className}`}>
  <svg
    width="30"
    height="30"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    class="shrink-0"
  >
    <defs>
      <linearGradient id="logo-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
        <stop stop-color="#2563EB" />
        <stop offset="1" stop-color="#10B981" />
      </linearGradient>
    </defs>
    <circle cx="16" cy="16" r="14.5" stroke="url(#logo-grad)" stroke-width="2" />
    <!-- camera aperture blades -->
    <path
      d="M16 7.5a8.5 8.5 0 0 1 7.36 4.25l-7.36.02 3.7-4.27ZM7.5 16a8.5 8.5 0 0 1 4.25-7.36l3.66 6.39-7.91.97ZM16 24.5a8.5 8.5 0 0 1-7.36-4.25l7.36-.02-3.7 4.27ZM24.5 16a8.5 8.5 0 0 1-4.25 7.36l-3.66-6.39 7.91-.97Z"
      fill="url(#logo-grad)"
      opacity="0.92"
    />
    <circle cx="16" cy="16" r="3" fill="#0b1220" />
  </svg>
  <span class="text-[1.15rem] font-semibold tracking-tight text-ink">{BRAND.name}</span>
</span>
