---
import { resolveLocale } from "../i18n/utils";
import { homeContent } from "../content/home";
import type { Locale } from "../config";

const locale: Locale = resolveLocale(Astro.currentLocale);
const a = homeContent[locale].ask;

const railTone = ["brand", "signal", "violet"] as const;
const railClass: Record<string, string> = {
  brand: "bg-brand-50 text-brand-600",
  signal: "bg-signal-50 text-signal-600",
  violet: "bg-violet-50 text-violet-500",
};
const bars = [38, 52, 45, 64, 58, 80, 72];
---
<section id="agentic" class="bg-mist">
  <div class="container-x grid items-center gap-12 py-16 md:py-24 lg:grid-cols-[0.95fr_1.05fr]">
    <!-- Left: copy + Ask/Monitor/Act rail -->
    <div>
      <span class="eyebrow">{a.eyebrow}</span>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">
        {a.title} <span class="text-brand-600">{a.titleAccent}</span>
      </h2>
      <p class="mt-4 max-w-md text-muted">{a.sub}</p>

      <ol class="mt-8 space-y-3">
        {
          a.rail.map((step, i) => (
            <li class="surface-card flex gap-4 p-5">
              <span class={`sys-tag mt-0.5 flex h-7 shrink-0 items-center rounded px-2 ${railClass[railTone[i]]}`}>
                {step.tag}
              </span>
              <div>
                <h3 class="text-base font-semibold text-ink">{step.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-muted">{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <!-- Right: agent chat panel (static HTML, CSS-only reveal) -->
    <div class="surface-card overflow-hidden">
      <div class="flex items-center gap-3 border-b border-line bg-mist px-5 py-3.5">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-signal-500">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><circle cx="12" cy="12" r="3"/><path d="M12 3a9 9 0 0 1 7.8 4.5L12 7.5 15.9 3.5A9 9 0 0 0 12 3Z"/></svg>
        </span>
        <div class="flex-1">
          <div class="text-sm font-semibold text-ink">{a.agentName}</div>
          <div class="flex items-center gap-1.5 text-xs text-signal-600">
            <span class="h-1.5 w-1.5 rounded-full bg-signal-500"></span>{a.online}
          </div>
        </div>
        <span class="sys-tag text-faint">LIVE</span>
      </div>

      <div class="chat-reveal flex flex-col gap-4 bg-canvas p-5">
        {
          a.exchanges.map((ex, i) => (
            <>
              <div class="chat-msg flex justify-end" style={`--i:${i * 2}`}>
                <p class="max-w-[80%] rounded-2xl rounded-br-md bg-brand-600 px-4 py-2.5 text-sm text-white">
                  {ex.q}
                </p>
              </div>
              <div class="chat-msg flex gap-2.5" style={`--i:${i * 2 + 1}`}>
                <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-brand-500 to-signal-500">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="#fff"><circle cx="12" cy="12" r="3"/></svg>
                </span>
                <div class="max-w-[82%] rounded-2xl rounded-bl-md border border-line bg-mist px-4 py-3">
                  <p class="text-sm leading-relaxed text-ink">{ex.a}</p>

                  {ex.kind === "stat" && (
                    <div class="mt-3 flex items-end justify-between gap-4">
                      <div>
                        <div class="font-mono text-2xl font-bold text-ink">{ex.value}</div>
                        {ex.delta && <div class="sys-tag text-signal-600">{ex.delta}</div>}
                        {ex.note && <div class="sys-tag text-faint">{ex.note}</div>}
                      </div>
                      <div class="flex h-10 items-end gap-1" aria-hidden="true">
                        {bars.map((h) => (
                          <span class="w-2 rounded-sm bg-gradient-to-t from-brand-600 to-signal-500" style={`height:${h}%`} />
                        ))}
                      </div>
                    </div>
                  )}

                  {ex.kind === "alert" && ex.note && (
                    <div class="mt-3 inline-flex items-center gap-2 rounded-lg border border-signal-500/30 bg-signal-50 px-3 py-1.5">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
                      <span class="sys-tag text-signal-600">{ex.note}</span>
                    </div>
                  )}

                  {ex.kind === "clip" && (
                    <div class="relative mt-3 flex aspect-video max-w-[16rem] items-center justify-center overflow-hidden rounded-lg border border-line bg-mist-2">
                      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-600">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
                      </span>
                      {ex.note && <span class="absolute bottom-2 left-2 sys-tag text-muted">{ex.note}</span>}
                    </div>
                  )}
                </div>
              </div>
            </>
          ))
        }
      </div>

      <div class="border-t border-line p-3">
        <div class="flex items-center gap-2 rounded-full border border-line-strong bg-canvas py-2 pl-4 pr-2">
          <span class="flex-1 truncate text-sm text-faint">{a.inputHint}</span>
          <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-600">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
