---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  class?: string;
}
const { href, variant = "primary", size = "md", class: className = "" } = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-full font-medium transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 focus-visible:ring-offset-canvas";

const sizes = {
  md: "px-5 py-2.5 text-sm",
  lg: "px-7 py-3.5 text-base",
};

const variants = {
  primary:
    "bg-brand-600 text-white hover:bg-brand-500 shadow-[0_10px_24px_-10px_rgba(37,99,235,0.6)] hover:-translate-y-0.5",
  secondary:
    "border border-line-strong bg-surface text-ink hover:border-brand-500 hover:bg-mist",
  ghost: "text-muted hover:text-ink",
};
---
<a href={href} class={`${base} ${sizes[size]} ${variants[variant]} ${className}`}>
  <slot />
</a>
