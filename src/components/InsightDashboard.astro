---
import { resolveLocale } from "../i18n/utils";
import { BRAND, type Locale } from "../config";

const locale: Locale = resolveLocale(Astro.currentLocale);

const t = {
  en: {
    panel: "Store 12",
    live: "Live",
    today: "Today",
    visitors: "Visitors today",
    conversion: "Conversion",
    dwell: "Avg dwell",
    queue: "Queue",
    waiting: "4 waiting",
    footfall: "Footfall by hour",
    peak: "Peak 6–8 PM",
    funnel: "Conversion funnel",
    gender: "Gender split",
    male: "Male",
    female: "Female",
    stages: ["Visitors", "Interested", "Interacted", "Billed"],
    alert: "Safety alert",
    ppe: "PPE missing · Dock A · 14:32",
    viewClip: "View clip",
    sent: "Sent on WhatsApp",
    sentBody: "PPE alert · Dock A",
    start: "10 AM",
    end: "8 PM",
  },
  hi: {
    panel: "स्टोर 12",
    live: "लाइव",
    today: "आज",
    visitors: "आज विज़िटर",
    conversion: "कन्वर्शन",
    dwell: "औसत ड्वेल",
    queue: "कतार",
    waiting: "4 प्रतीक्षारत",
    footfall: "घंटे अनुसार फुटफॉल",
    peak: "पीक 6–8 PM",
    funnel: "कन्वर्शन फ़नल",
    gender: "लिंग विभाजन",
    male: "पुरुष",
    female: "महिला",
    stages: ["विज़िटर", "रुचि", "संपर्क", "बिल"],
    alert: "सुरक्षा अलर्ट",
    ppe: "PPE गायब · डॉक A · 14:32",
    viewClip: "क्लिप देखें",
    sent: "व्हाट्सऐप पर भेजा",
    sentBody: "PPE अलर्ट · डॉक A",
    start: "10 AM",
    end: "8 PM",
  },
}[locale];

const bars = [34, 46, 40, 56, 50, 68, 62, 84, 74];
const funnel = [
  { w: "100%", v: "1,284" },
  { w: "74%", v: "951" },
  { w: "52%", v: "668" },
  { w: "38%", v: "488" },
];

const kpis = [
  { label: t.visitors, value: "1,284", note: "▲ +12%", tone: "text-signal-600" },
  { label: t.conversion, value: "38%", note: "of footfall", tone: "text-faint" },
  { label: t.dwell, value: "4m 12s", note: "+6%", tone: "text-signal-600" },
  { label: t.queue, value: "2.3m", note: t.waiting, tone: "text-warn-500" },
];
---
<div class="relative mx-auto w-full max-w-lg lg:max-w-none lg:pt-6">
  <div class="surface-card overflow-hidden">
    <!-- window chrome -->
    <div class="flex items-center gap-2 border-b border-line bg-mist px-4 py-2.5">
      <span class="h-2.5 w-2.5 rounded-full bg-danger-500/60"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-warn-500/60"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-signal-500/60"></span>
      <span class="ml-2 flex items-center gap-1.5 rounded-md bg-canvas px-2.5 py-1 font-mono text-[0.65rem] text-faint">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        {BRAND.appHost}/dashboard
      </span>
    </div>

    <div class="space-y-6 p-5 md:p-6">
      <!-- header -->
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2.5">
          <span class="text-base font-semibold text-ink">{t.panel}</span>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-signal-50 px-2 py-0.5">
            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-signal-500"></span>
            <span class="sys-tag text-signal-600">{t.live}</span>
          </span>
        </div>
        <span class="rounded-full bg-mist px-3 py-1 sys-tag text-faint">{t.today}</span>
      </div>

      <!-- KPI strip -->
      <div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-4">
        {
          kpis.map((k) => (
            <div class="bg-surface p-3.5">
              <div class="sys-tag truncate text-faint">{k.label}</div>
              <div class="mt-1.5 text-lg font-bold leading-none text-ink">{k.value}</div>
              <div class={`mt-1.5 sys-tag ${k.tone}`}>{k.note}</div>
            </div>
          ))
        }
      </div>

      <!-- footfall chart -->
      <div>
        <div class="flex items-center justify-between">
          <span class="sys-tag text-faint">{t.footfall}</span>
          <span class="sys-tag text-brand-600">{t.peak}</span>
        </div>
        <div class="mt-3 flex h-28 items-end gap-2 border-b border-line pb-px">
          {
            bars.map((h, i) => (
              <span class="bar-anim flex-1 rounded-t-md bg-gradient-to-t from-brand-600 to-brand-400" style={`height:${h}%;--i:${i}`} />
            ))
          }
        </div>
        <div class="mt-2 flex justify-between sys-tag text-faint">
          <span>{t.start}</span>
          <span>{t.end}</span>
        </div>
      </div>

      <!-- funnel + gender -->
      <div class="grid gap-4 sm:grid-cols-[1.4fr_1fr]">
        <div class="rounded-2xl border border-line p-4">
          <span class="sys-tag text-faint">{t.funnel}</span>
          <div class="mt-3 space-y-2">
            {
              funnel.map((f, i) => (
                <div class="flex items-center gap-2.5">
                  <span class="w-14 shrink-0 truncate text-[0.7rem] text-muted">{t.stages[i]}</span>
                  <div class="h-4 flex-1 rounded bg-mist">
                    <div class="flex h-4 items-center justify-end rounded bg-gradient-to-r from-signal-600 to-signal-400 pr-1.5" style={`width:${f.w}`}>
                      <span class="text-[0.6rem] font-semibold text-white">{f.v}</span>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="flex flex-col items-center justify-center rounded-2xl border border-line p-4">
          <span class="self-start sys-tag text-faint">{t.gender}</span>
          <div class="relative mt-2 h-20 w-20" style="background:conic-gradient(var(--color-brand-500) 0 49%, var(--color-violet-500) 49% 100%);border-radius:9999px">
            <span class="absolute inset-[26%] rounded-full bg-surface"></span>
          </div>
          <div class="mt-3 flex w-full items-center justify-center gap-3">
            <span class="flex items-center gap-1.5 text-[0.7rem] text-muted"><span class="h-2 w-2 rounded-full bg-brand-500"></span>49% {t.male}</span>
            <span class="flex items-center gap-1.5 text-[0.7rem] text-muted"><span class="h-2 w-2 rounded-full bg-violet-500"></span>51% {t.female}</span>
          </div>
        </div>
      </div>

      <!-- alert strip -->
      <div class="flex items-center gap-3 rounded-2xl border border-danger-500/20 bg-danger-50 p-3.5">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-danger-500/10">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z"/></svg>
        </span>
        <div class="min-w-0 flex-1">
          <div class="sys-tag text-danger-500">{t.alert}</div>
          <div class="truncate text-sm font-medium text-ink">{t.ppe}</div>
        </div>
        <span class="shrink-0 rounded-lg border border-line bg-surface px-3 py-1.5 text-xs font-medium text-ink">{t.viewClip}</span>
      </div>
    </div>
  </div>

  <!-- single floating WhatsApp notification (peeks above top-right; over empty space, never content) -->
  <div class="float-card float-anim absolute -top-3 right-3 hidden w-56 items-center gap-2.5 p-3 lg:flex">
    <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-signal-500">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2Zm5.3 13.9c-.2.6-1.2 1.1-1.7 1.2-.5.1-1 .1-1.6-.1-.4-.1-.9-.3-1.5-.5-2.6-1.1-4.3-3.7-4.4-3.9-.1-.2-1-1.4-1-2.6s.6-1.8.9-2.1c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.7 1.7c.1.2.1.4 0 .5l-.3.4-.3.3c-.1.1-.3.3-.1.5.1.3.6 1 1.3 1.6.9.8 1.6 1 1.9 1.1.2.1.4.1.5-.1l.6-.7c.2-.2.3-.2.5-.1l1.6.8c.2.1.4.2.4.3.1.1.1.5 0 1Z"/></svg>
    </span>
    <div class="min-w-0">
      <div class="sys-tag text-signal-600">{t.sent}</div>
      <div class="truncate text-xs font-medium text-ink">{t.sentBody}</div>
    </div>
  </div>
</div>
